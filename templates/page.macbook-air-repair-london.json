    "custom_liquid_repairs_p6a": {
      "type": "custom-liquid",
      "name": "Repairs",
      "settings": {
        "custom_liquid": "<style>\n.repair-categories {\n  max-width: 950px;\n  margin: 0 auto 80px auto;\n}\n\n.repair-category {\n  background: #ebecf0;\n  border-radius: 12px;\n  padding: 35px;\n  margin-bottom: 30px;\n  border-left: 5px solid #111;\n}\n\n.repair-category h3 {\n  font-size: 26px;\n  margin-bottom: 14px;\n}\n\n.repair-category p,\n.repair-category li {\n  font-size: 16px;\n  line-height: 1.65;\n  color: #555;\n}\n\n.repair-link {\n  display: inline-block;\n  background:#111;\n  color:#fff !important;\n  padding: 12px 28px;\n  border-radius: 6px;\n  margin-top: 10px;\n  font-weight: 600;\n}\n\n@media (max-width: 900px) {\n  .repair-category { padding: 25px 20px; }\n}\n<\/style>\n\n<section id=\"repair-categories\" class=\"repair-categories\">\n\n<div class=\"repair-category\" style=\"text-align: start;\">\n<h3>MacBook Air Screen Replacement<\/h3>\n<p>Cracked or faulty Retina display? We replace MacBook Air screens on all models using genuine Apple panels.<\/p>\n<a class=\"repair-link\" href=\"\/collections\/macbook-screen-repair-prices\">View Screen Prices \u2192<\/a>\n<\/div>\n\n<div class=\"repair-category\" style=\"text-align: start;\">\n<h3>MacBook Air Battery Replacement<\/h3>\n<p>Swollen, degraded, or failing battery? Fast replacement with quality cells matched to original specifications.<\/p>\n<a class=\"repair-link\" href=\"\/collections\/macbook-battery-repair-prices\">View Battery Pricing \u2192<\/a>\n<\/div>\n\n<div class=\"repair-category\" style=\"text-align: start;\">\n<h3>MacBook Liquid Damage Repair<\/h3>\n<p>Logic board restoration, ultrasonic cleaning, corrosion removal and component-level recovery after liquid spills.<\/p>\n<a class=\"repair-link\" href=\"\/collections\/macbook-repair-prices\">View Liquid Damage Pricing \u2192<\/a>\n<\/div>\n\n<div class=\"repair-category\" style=\"text-align: start;\">\n<h3>MacBook Diagnostic Service<\/h3>\n<p>Comprehensive diagnostic identifying all hardware and software faults with a full written report.<\/p>\n<a class=\"repair-link\" href=\"\/collections\/macbook-diagnostic-prices\">Book Diagnostic Service \u2192<\/a>\n<\/div>\n\n<\/section>",
