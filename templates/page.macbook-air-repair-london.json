    "custom_liquid_faqs_p6a": {
      "type": "custom-liquid",
      "name": "FAQs",
      "settings": {
        "custom_liquid": "<style>\n.faq-section {\n  background:#ebecf0;\n  max-width: 950px;\n  margin: 0 auto 70px auto;\n  padding:50px 30px;\n  border-radius:14px;\n}\n\n.faq-section h2 {\n  text-align:center;\n  font-size:34px;\n  margin-bottom:40px;\n}\n\n.faq-item {\n  background:#fff;\n  padding:22px;\n  border-left:4px solid #111;\n  border-radius:8px;\n  margin-bottom:20px;\n}\n\n.faq-item h3 {\n  font-size:19px;\n  margin-bottom:10px;\n}\n\n@media (max-width: 900px) {\n  .faq-section { padding: 35px 18px; }\n}\n<\/style>\n\n<section class=\"faq-section\">\n<h2>MacBook Air Repair London FAQs<\/h2>\n\n<div class=\"faq-item\">\n<h3><strong>Which MacBook Air models do you repair in London?<\/strong><\/h3>\n<p>We repair all MacBook Air models: 13\" and 15\", Intel and Apple Silicon (M1, M2, M3). Walk-in at our London centre or use our UK mail-in service.<\/p>\n<\/div>\n\n<div class=\"faq-item\">\n<h3><strong>Can you fix a MacBook Air that won\u2019t charge?<\/strong><\/h3>\n<p>Yes. Charging failures on MacBook Air are usually caused by a faulty USB-C port, charging IC, or liquid damage. We diagnose and repair at component level \u2014 not by replacing the entire board.<\/p>\n<\/div>\n\n<div class=\"faq-item\">\n<h3><strong>How long does MacBook Air repair take?<\/strong><\/h3>\n<p>Most standard repairs (screens, batteries) are completed within 24 hours. Logic board and liquid damage repairs typically take 3\u20135 working days. Express same-day is available for common faults.<\/p>\n<\/div>\n\n<div class=\"faq-item\">\n<h3><strong>Do you offer no-fix no-fee on MacBook Air repairs?<\/strong><\/h3>\n<p>Yes. For standard repairs, if we can\u2019t fix it, you don\u2019t pay. A diagnostic fee applies for logic board assessments where repair isn\u2019t possible.<\/p>\n<\/div>\n\n<div class=\"faq-item\">\n<h3><strong>Is there a warranty on MacBook Air repairs?<\/strong><\/h3>\n<p>All MacBook Air repairs include a 2-year warranty covering the repaired components and associated workmanship.<\/p>\n<\/div>\n\n<\/section>\n\n<script type=\"application\/ld+json\">\n{\n  \"@context\": \"https:\/\/schema.org\",\n  \"@type\": \"LocalBusiness\",\n  \"name\": \"iCorrect\",\n  \"image\": \"https:\/\/cdn.shopify.com\/s\/files\/1\/0674\/1952\/0525\/files\/MacBook_Repair.png\",\n  \"url\": \"https:\/\/www.icorrect.co.uk\/pages\/macbook-air-repair-london\",\n  \"telephone\": \"+442080049995\",\n  \"address\": {\n    \"@type\": \"PostalAddress\",\n    \"streetAddress\": \"12 Margaret Street\",\n    \"addressLocality\": \"London\",\n    \"postalCode\": \"W1W 8JQ\",\n    \"addressCountry\": \"GB\"\n  },\n  \"geo\": {\n    \"@type\": \"GeoCoordinates\",\n    \"latitude\": 51.5175,\n    \"longitude\": -0.1418\n  },\n  \"openingHoursSpecification\": [\n    {\n      \"@type\": \"OpeningHoursSpecification\",\n      \"dayOfWeek\": [\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\"],\n      \"opens\": \"09:00\",\n      \"closes\": \"18:00\"\n    }\n  ],\n  \"priceRange\": \"\u00a3\u00a3\",\n  \"description\": \"MacBook Air repair specialists in London. Screen, battery, charging, keyboard and logic board repairs. M1, M2, M3 models. 2-year warranty.\"\n}\n<\/script>",
