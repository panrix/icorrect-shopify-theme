    "custom_liquid_repairs": {
      "type": "custom-liquid",
      "name": "Repairs",
      "settings": {
        "custom_liquid": "<style>\n.repair-categories {\n  max-width: 950px;\n  margin: 0 auto 80px auto;\n}\n\n.repair-category {\n  background: #ebecf0;\n  border-radius: 12px;\n  padding: 35px;\n  margin-bottom: 30px;\n  border-left: 5px solid #111;\n}\n\n.repair-category h3 {\n  font-size: 26px;\n  margin-bottom: 14px;\n}\n\n.repair-category p,\n.repair-category li {\n  font-size: 16px;\n  line-height: 1.65;\n  color: #555;\n}\n\n.repair-link {\n  display: inline-block;\n  background:#111;\n  color:#fff !important;\n  padding: 12px 28px;\n  border-radius: 6px;\n  margin-top: 10px;\n  font-weight: 600;\n}\n\n@media (max-width: 900px) {\n  .repair-category { padding: 25px 20px; }\n}\n</style>\n\n<section id=\"repair-categories\" class=\"repair-categories\">\n\n<div class=\"repair-category\" style=\"text-align: start;\">\n<h3>MacBook Screen Replacement</h3>\n<p>Cracked, shattered, or visually damaged MacBook displays replaced with genuine LCD panels. We restore full clarity, True Tone, and brightness to factory standards.</p>\n<a class=\"repair-link\" href=\"/collections/macbook-screen-repair-prices\">View Screen Replacement Pricing →</a>\n</div>\n\n<div class=\"repair-category\" style=\"text-align: start;\">\n<h3>MacBook Flexgate Repair</h3>\n<p>We repair the backlight cable fault known as Flexgate on 2016–2019 MacBook Pro models. Our component-level fix restores even backlighting without replacing the entire display.</p>\n<a class=\"repair-link\" href=\"/collections/macbook-flexgate-repair-prices\">View Flexgate Repair Pricing →</a>\n</div>\n\n<div class=\"repair-category\" style=\"text-align: start;\">\n<h3>MacBook Diagnostic Service</h3>\n<p>Not sure what's wrong with your MacBook screen? Our comprehensive diagnostic identifies display faults, backlight issues, and cable damage with a full written report before any work begins.</p>\n<a class=\"repair-link\" href=\"/collections/macbook-diagnostic-prices\">Book Diagnostic Service →</a>\n</div>\n\n</section>",
        "color_scheme": "",
        "padding_top": 52,
        "padding_bottom": 0
