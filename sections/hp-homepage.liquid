 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg></div></div><h3>Apple said new logic board. It was one chip.</h3><p>Quoted £1,400 for a board swap. iCorrect traced it to the backlight IC and repaired it under the microscope. Same Mac, my data untouched.</p><footer class="review-card-foot"><strong>Daniel R.</strong><span>MBP 16" M1 Max · Google</span></footer></article><article class="review-card hp-reveal"><div class="review-card-top"><span class="review-card-tag">Recovery</span><div class="review-card-stars"><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg></div></div><h3>Liquid damage. They returned my data.</h3><p>Apple wrote it off after a wine spill. Cleaned the board, replaced the flex, recovered every file.</p><footer class="review-card-foot"><strong>Henrietta W.</strong><span>MBA 13" M2 · Google</span></footer></article><article class="review-card hp-reveal"><div class="review-card-top"><span class="review-card-tag">Free re-work</span><div class="review-card-stars"><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg></div></div><h3>Stage Light gone. Warranty honoured.</h3><p>Classic flex-cable failure. Re-did the work for free under warranty 9 months later. No quibbles.</p><footer class="review-card-foot"><strong>Marcus T.</strong><span>MBP 16" M1 Max · Google</span></footer></article><article class="review-card hp-reveal"><div class="review-card-top"><span class="review-card-tag">Same day</span><div class="review-card-stars"><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg><svg viewBox="0 0 14 14" width="11" height="11"><path d="M7 1l1.8 3.8 4.2.6-3 2.9.7 4.1L7 10.5 3.3 12.4l.7-4.1-3-2.9 4.2-.6z" style="fill: var(--ic-star, #f59e0b);"></path></svg></div></div><h3>Walked in at 9. Working screen by lunch.</h3><p>Genuine display fitted while I worked across the road. The price I was quoted online was the price I paid.</p><footer class="review-card-foot"><strong>Priya S.</strong><span>iPhone 15 Pro · Google</span></footer></article></div></div></section><section class="hp-section hp-datasafety"><div class="container"><div class="hp-section-head"><div><div class="hp-section-eyebrow">Data &amp; privacy</div><h2 class="hp-section-title">Your data stays on your device.</h2></div><p class="hp-section-lede">We're board-level hardware specialists, not IT support. We don't need your passwords, we don't image your drive, and we don't plug your Mac into our network.</p></div><div class="hp-datasafety-grid"><div class="hp-datasafety-card hp-reveal hp-reveal-d1"><span class="hp-datasafety-num">01</span><h3>Screen repairs never touch your drive</h3><p>The display is a separate assembly. We replace it without powering on — your data doesn't enter the equation.</p></div><div class="hp-datasafety-card hp-reveal hp-reveal-d2"><span class="hp-datasafety-num">02</span><h3>GDPR-compliant workshop</h3><p>No passcodes requested unless post-repair testing requires it — and you can be present for that step. NDA on request for corporate clients.</p></div><div class="hp-datasafety-card hp-reveal hp-reveal-d3"><span class="hp-datasafety-num">03</span><h3>No cloud, no sync</h3><p>Your device doesn't connect to our network. Diagnosis happens on an isolated bench with board-level tools, not software.</p></div></div></div></section><section class="hp-section hp-priceconf"><div class="container"><div class="hp-section-head"><div><div class="hp-section-eyebrow">Pricing</div><h2 class="hp-section-title">The quote is the price. No surprises.</h2></div><p class="hp-section-lede">We don't lowball to get you through the door and then discover "additional damage." If diagnosis reveals something we didn't expect, we call you with an updated quote before touching anything.</p></div><div class="hp-priceconf-grid"><div class="hp-priceconf-card hp-priceconf-card-main"><div class="hp-priceconf-row"><span class="hp-priceconf-label">Fixed-price repairs</span><span class="hp-priceconf-value">Screen, battery, rear glass — priced by model, not by mood.</span></div><div class="hp-priceconf-row"><span class="hp-priceconf-label">Bench diagnosis</span><span class="hp-priceconf-value">£49, paid at booking, covers bench diagnosis; your repair is quoted separately for approval.</span></div><div class="hp-priceconf-row"><span class="hp-priceconf-label">No hidden fees</span><span class="hp-priceconf-value">The price includes parts, labour, calibration, QA, and a 2-year warranty. Collection and return are the only add-on.</span></div></div><div class="hp-priceconf-compare"><div class="hp-priceconf-compare-head"><span>Why we're different from Apple</span></div><div class="hp-priceconf-row-compare"><span class="hp-priceconf-compare-label">Backlight IC failure</span><div class="hp-priceconf-compare-prices"><span class="hp-priceconf-compare-theirs">Apple: <strong>£1,400</strong> <em>(full board swap)</em></span><span class="hp-priceconf-compare-ours">iCorrect: <strong>£380</strong> <em>(chip replacement)</em></span></div></div><div class="hp-priceconf-row-compare"><span class="hp-priceconf-compare-label">MacBook Pro 14" screen</span><div class="hp-priceconf-compare-prices"><span class="hp-priceconf-compare-theirs">Apple: <strong>£669</strong></span><span class="hp-priceconf-compare-ours">iCorrect: <strong>£449</strong></span></div></div></div></div></div></section><section class="hp-section hp-access"><div class="container"><div class="hp-section-head"><div><div class="hp-section-eyebrow">Getting your device to us</div><h2 class="hp-section-title">Three ways in. One standard of repair.</h2></div><p class="hp-section-lede">Walk in from Oxford Circus, send a London courier, or post it from anywhere in the UK. Every repair uses the same bench, the same parts, the same warranty.</p></div><div class="hp-access-grid"><div class="hp-access-card hp-reveal hp-reveal-d1"><div class="hp-access-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4M10 17l5-5-5-5M15 12H3"></path></svg></div><h3 class="hp-access-title">Walk in</h3><div class="hp-access-detail">12 Margaret Street, Fitzrovia W1W 8JQ</div><div class="hp-access-meta">Free · Mon–Fri · No appointment needed</div><p class="hp-access-body">Opposite The London Palladium. Free diagnosis while you wait. Most screen and battery repairs returned same-day or next-day.</p></div><div class="hp-access-card hp-reveal hp-reveal-d2"><div class="hp-access-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="6" width="22" height="12" rx="2"></rect><path d="M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2M12 12v.01"></path></svg></div><h3 class="hp-access-title">Same-day courier</h3><div class="hp-access-detail">London postcodes only</div><div class="hp-access-meta">+ £20 · Collected within 3 hours</div><p class="hp-access-body">We send a tracked courier to your door. Your device is on the bench the same day, returned as soon as the repair's done.</p></div><div class="hp-access-card hp-reveal hp-reveal-d3"><div class="hp-access-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 8V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2h14a2 2 0 002-2v-2"></path><path d="M16 2v4M8 2v4M3 10h18"></path></svg></div><h3 class="hp-access-title">UK-wide mail-in</h3><div class="hp-access-detail">Pre-paid tracked shipping</div><div class="hp-access-meta">+ £24 · Next-day collection kit</div><p class="hp-access-body">We send you a pre-paid, insured shipping kit. Post it, we repair it, we courier it back. Same warranty, same quality.</p></div></div></div></section><section class="hp-section hp-corporate"><div class="container hp-corporate-inner"><div class="hp-corporate-text"><div class="hp-section-eyebrow" style="color: rgb(163, 163, 163);">Specialist &amp; Corporate</div><h2 class="hp-corporate-title">When it's business-critical,<br>skip the queue.</h2><p class="hp-corporate-body">Time-sensitive data recovery. Fleet repairs on retainer. The device Apple said was a write-off that your board presentation lives on. We handle the cases other shops won't touch — and we don't route you through a chatbot to get there.</p><ul class="hp-corporate-list"><li>Priority bench slot — same-day or next-day turnaround</li><li>Dedicated technician, not a call centre</li><li>NDA, audit trail, GDPR-compliant handling</li><li>Fleet pricing for 5+ devices</li></ul><a href="/pages/corporate-service" class="hp-corporate-cta">Talk to a specialist →</a></div><div class="hp-corporate-aside"><div class="hp-corporate-stat hp-reveal hp-reveal-d1"><span class="hp-corporate-stat-num">94%</span><span class="hp-corporate-stat-label">Data recovered from "dead" Macs in 2025</span></div><div class="hp-corporate-stat hp-reveal hp-reveal-d2"><span class="hp-corporate-stat-num">4 h</span><span class="hp-corporate-stat-label">Average turnaround on priority bench repairs</span></div><div class="hp-corporate-stat hp-reveal hp-reveal-d3"><span class="hp-corporate-stat-num">NDA</span><span class="hp-corporate-stat-label">Signed on request for every corporate job</span></div></div></div></section><section class="hp-section hp-faq" id="faq"><div class="container hp-faq-grid"><div class="hp-faq-left"><div class="hp-section-eyebrow">Frequently asked</div><h2 class="hp-section-title">Questions, answered honestly.</h2><p style="font: 400 16px/1.55 var(--font-sans); color: rgb(77, 77, 77); margin-top: 16px; text-wrap: pretty;">If your question isn't here, call <a href="tel:+442070998517" style="color: rgb(23, 23, 23); font-weight: 500;">+44 (0)207 099 8517</a> or drop in — we're opposite The London Palladium.</p></div><div class="hp-faq-right"><div class="hp-faq-item is-open"><button class="hp-faq-q"><span>How long does a repair take?</span><span class="hp-faq-icon" aria-hidden="true">+</span></button><div class="hp-faq-a">Most screen and battery repairs are done in 1–2 working days. Walk in before 11am with a common repair and same-day turnaround is usually possible. Board-level work (backlight IC, liquid damage) takes 3–5 days because we need to scope, repair, and QA under the microscope.</div></div><div class="hp-faq-item"><button class="hp-faq-q"><span>Are the parts genuine Apple?</span><span class="hp-faq-icon" aria-hidden="true">+</span></button></div><div class="hp-faq-item"><button class="hp-faq-q"><span>Is my data safe?</span><span class="hp-faq-icon" aria-hidden="true">+</span></button></div><div class="hp-faq-item"><button class="hp-faq-q"><span>What does the 2-year warranty cover?</span><span class="hp-faq-icon" aria-hidden="true">+</span></button></div><div class="hp-faq-item"><button class="hp-faq-q"><span>Do I need to book, or can I walk in?</span><span class="hp-faq-icon" aria-hidden="true">+</span></button></div><div class="hp-faq-item"><button class="hp-faq-q"><span>What if Apple says it's unfixable?</span><span class="hp-faq-icon" aria-hidden="true">+</span></button></div></div></div></section><section class="hp-finalcta"><div class="container hp-finalcta-inner"><h2>Ready to get it fixed?</h2><p>Tell us your device and the symptom. See your price in 60 seconds — or let us diagnose it properly first.</p><div class="hp-finalcta-row"><a href="#wizard" class="hp-cta hp-cta-primary hp-cta-lg">Get a quote <span class="arrow">→</span></a></div></div></section><footer class="icfooter"><div class="container icfooter-inner"><div><div class="icnav-logo" style="color: rgb(255, 255, 255);">iCorrect</div><div class="icfooter-tag">Apple repair specialists · Fitzrovia, London</div><div class="icfooter-tag">12 Margaret Street, London W1W 8JQ · <a href="mailto:support@icorrect.co.uk">support@icorrect.co.uk</a> · <a href="tel:+442070998517">020 7099 8517</a></div><div class="icfooter-tag">Independent repair specialist. Not affiliated with Apple Inc.</div></div><div class="icfooter-cols"><div><div class="mono-label" style="color: rgb(128, 128, 128);">Repairs</div><a href="/pages/macbook-repairs">MacBook</a><a href="/collections/macbook-screen-repair">MacBook Screen</a><a href="/pages/liquid-damage-process">Liquid damage</a><a href="/pages/advanced-diagnostics">Board-level</a><a href="#">iPhone</a><a href="#">iPad</a></div><div><div class="mono-label" style="color: rgb(128, 128, 128);">Company</div><a href="/pages/about">Why us</a><a href="/pages/corporate-service">Corporate</a><a href="/pages/how-it-works">How it works</a><a href="/pages/repair-case-study">Case study</a><a href="/pages/careers">Careers</a><a href="/pages/contact">Contact</a></div><div><div class="mono-label" style="color: rgb(128, 128, 128);">Legal</div><a href="#">Warranty</a><a href="#">Privacy</a><a href="#">Terms</a></div></div></div><div class="container icfooter-base"><span>© 2026 iCorrect Ltd. Not affiliated with Apple Inc.</span><span>Company No. 09392844 · VAT GB 203495788</span></div></footer><a class="hp-floating-quote" href="#wizard">Get a quote <spa