{%- liquid
  assign review_copy = '719+ Google reviews · 4.8'
  assign rating = '4.8'
  assign review_count = '719+'

  assign diagnostic_price_cents = 4900
  if section.settings.diagnostic_product != blank and section.settings.diagnostic_product.selected_or_first_available_variant != blank
    assign diagnostic_price_cents = section.settings.diagnostic_product.selected_or_first_available_variant.price
  endif
  assign backlight_price_cents = 38000
  if section.settings.backlight_product != blank and section.settings.backlight_product.selected_or_first_available_variant != blank
    assign backlight_price_cents = section.settings.backlight_product.selected_or_first_available_variant.price
  endif
  assign macbook_screen_price_cents = 44900
  if section.settings.macbook_screen_product != blank and section.settings.macbook_screen_product.selected_or_first_available_variant != blank
    assign macbook_screen_price_cents = section.settings.macbook_screen_product.selected_or_first_available_variant.price
  endif

  assign apple_board_quote = 140000 | money_without_trailing_zeros
  assign apple_screen_quote = 66900 | money_without_trailing_zeros
  assign diagnostic_fee = diagnostic_price_cents | money_without_trailing_zeros
  assign backlight_price = backlight_price_cents | money_without_trailing_zeros
  assign macbook_screen_price = macbook_screen_price_cents | money_without_trailing_zeros
  assign backlight_saving_cents = 140000 | minus: backlight_price_cents
  assign backlight_saving = backlight_saving_cents | money_without_trailing_zeros
  assign courier_fee = 2000 | money_without_trailing_zeros
  assign mail_fee = 2400 | money_without_trailing_zeros
-%}

<div class="icorrect-homepage" data-section-id="{{ section.id }}">
  <nav class="icnav" data-hp-nav>
    <div class="container icnav-inner">
      <a class="icnav-logo" href="{{ routes.root_url }}">iCorrect</a>
