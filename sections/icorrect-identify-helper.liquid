{{ 'icorrect-redesign-tokens.css' | asset_url | stylesheet_tag }}
{{ 'icorrect-collection-redesign.css' | asset_url | stylesheet_tag }}
<script src="{{ 'icorrect-collection-redesign.js' | asset_url }}" defer="defer"></script>

<section class="icr-design identify" id="identify">
  <div class="container identify-grid">
    <div class="identify-visual" aria-hidden="true">
      <div class="identify-visual-inner">
        <div class="identify-plate">
          <div class="identify-plate-line">Designed by Apple in California.</div>
          <div class="identify-plate-line muted">Assembled in China</div>
          <div class="identify-plate-line highlight">Model <span class="hl">{{ section.settings.example_code }}</span></div>
          <div class="identify-plate-line muted small">EMC 3650 · 61W USB-C</div>
        </div>
        <div class="mono-label identify-hint">← Look on the underside</div>
      </div>
    </div>
    <div class="identify-text">
      <div class="mono-label">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.copy }}</p>
      <form class="identify-form" data-icr-identify-form>
        <label class="icr-visually-hidden" for="icr-identify-input-{{ section.id }}">Model number</label>
        <input id="icr-identify-input-{{ section.id }}" type="search" placeholder="{{ section.settings.placeholder }}" data-icr-identify-input>
        <button class="btn btn-dark" type="submit">{{ section.settings.button_label }}</button>
      </form>
      <div class="identify-foot"><span data-icr-identify-message>Or </span><a href="#wizard">browse models in the wizard →</a></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "iCorrect identify helper",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Not sure which model you have?" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your model number in 5 seconds." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Flip your MacBook over and look for a four-character code starting with A. Enter it here and we will try to match the repair below." },
    { "type": "text", "id": "example_code", "label": "Example model code", "default": "A2442" },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "e.g. A2442" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Identify" }
  ],
  "presets": [
    { "name": "iCorrect identify helper" }
  ]
}
{% endschema %}
