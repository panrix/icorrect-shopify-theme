    {%- for link in linklists['wizard-iphone-models'].links -%}
      {%- if link.links.size > 0 -%}
        { group: {{ link.title | json }}, models: [
          {%- for sub in link.links -%}
            { name: {{ sub.title | json }}, collectionHandle: "{{ sub.url | split: '/collections/' | last | split: '/' | first }}" }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]}{%- unless forloop.last -%},{%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  ],
  ipad: [
    {%- for link in linklists['wizard-ipad-models'].links -%}
      {%- if link.links.size > 0 -%}
        { group: {{ link.title | json }}, models: [
          {%- for sub in link.links -%}
            { name: {{ sub.title | json }}, collectionHandle: "{{ sub.url | split: '/collections/' | last | split: '/' | first }}" }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]}{%- unless forloop.last -%},{%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  ],
  watch: [
    {%- for link in linklists['wizard-watch-models'].links -%}
      {%- if link.links.size > 0 -%}
        { group: {{ link.title | json }}, models: [
          {%- for sub in link.links -%}
            { name: {{ sub.title | json }}, collectionHandle: "{{ sub.url | split: '/collections/' | last | split: '/' | first }}" }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]}{%- unless forloop.last -%},{%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
