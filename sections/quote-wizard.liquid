<!-- Subtask 1.1.2 — window.WIZARD_CONTEXT -->
<script>
window.WIZARD_CONTEXT = {
  pageType: "{{ template.name }}",
  collectionHandle: {{ collection.handle | default: '' | json }},
  productHandle: {{ product.handle | default: '' | json }},
  {%- if collection -%}
    device: {{ collection.metafields.custom.wizard_device | default: '' | json }},
    fault: {{ collection.metafields.custom.wizard_fault | default: '' | json }}
  {%- elsif product -%}
    device: {{ product.metafields.custom.wizard_device | default: '' | json }},
    fault: ""
  {%- else -%}
    device: "",
    fault: ""
  {%- endif -%}
};
</script>

<!-- Subtask 1.1.3 — HTML Skeleton -->
<div class="qw-section">
  <div class="qw-wrap">

    {%- if section.settings.show_map -%}
    <!-- LEFT: MAP + DETAILS -->
    <div class="qw-info">
      <div class="qw-map">
        {%- if section.settings.map_html != blank -%}
          {{ section.settings.map_html }}
        {%- else -%}
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2482.7925117760165!2d-0.1422392230845079!3d51.51702250999988!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x48761b2c5aabf83b%3A0x2abbd489a9d66382!2siCorrect!5e0!3m2!1sen!2sit!4v1766495755523!5m2!1sen!2sit" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="iCorrect London"></iframe>
        {%- endif -%}
      </div>
      <div class="qw-card qw-card-grid">
        <div class="qw-card-col qw-card-left">
          <div class="qw-d-group">
            <p class="qw-d-label"><svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>Address</p>
            <a href="https://maps.google.com/?q=iCorrect+12+Margaret+Street+London+W1W+8JQ" target="_blank" rel="noopener" class="qw-d-val">iCorrect<br>12 Margaret Street<br>Audley House<br>London W1W 8JQ</a>
          </div>
          <div class="qw-d-group">
            <p class="qw-d-label"><svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>Phone</p>
            <a href="tel:+442070998517" class="qw-d-val">+44 (0)207 099 8517</a>
          </div>
          <div class="qw-d-group">
            <p class="qw-d-label"><svg fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>Email</p>
