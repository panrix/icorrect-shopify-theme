  /* =============================================
     STEP NAVIGATION
     ============================================= */
  function go(n) {
    S.step = n;
    history.pushState({ step: n, device: S.device, model: S.model, fault: S.fault }, '');
    document.querySelectorAll('.qw-step').forEach(function(el) { el.classList.remove('on'); });
    document.getElementById('qw-s' + n).classList.add('on');
    updateProg(n);
    document.querySelector('.qw-wizard').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function updateProg(step) {
    document.querySelectorAll('.qw-prog-s').forEach(function(el) {
      var s = parseInt(el.dataset.s);
      el.classList.remove('on', 'done');
      if (s < step) el.classList.add('done');
      else if (s === step) el.classList.add('on');
    });
  }

  /* =============================================
     STEP 1: DEVICES
     ============================================= */
  function renderDevices() {
    var g = document.getElementById('qw-devGrid');
    DEVS.forEach(function(d) {
      var c = document.createElement('div');
      c.className = 'qw-dev';
      c.tabIndex = 0;
      c.setAttribute('role', 'button');
      c.innerHTML = '<div class="qw-dev-ico">' + d.icon + '</div><span class="qw-dev-lbl">' + d.label + '</span>';
      c.onclick = function() { pickDev(d.id, c); };
      c.onkeydown = function(e) { if (e.key === 'Enter') pickDev(d.id, c); };
      g.appendChild(c);
    });
  }

  function pickDev(id, el) {
    S.device = id; S.model = null; S.fault = null; S.issue = null;
    S.collectionHandle = null; _repairsMap = {};
    document.querySelectorAll('#qw-s1 .qw-dev').forEach(function(c) { c.classList.remove('sel'); });
    el.classList.add('sel');
    if (window.posthog) posthog.capture('wizard_step', { step: 2, device: S.device });
    setTimeout(function() { renderModels(id); go(2); }, 150);
  }

  /* =============================================
     STEP 2: MODELS (accordion groups)
     ============================================= */
  function renderModels(dev) {
    var c = document.getElementById('qw-mC'); c.innerHTML = '';
    document.getElementById('qw-s2t').textContent = 'Pick your ' + DN[dev] + ' model';
    document.getElementById('qw-hP').classList.remove('open');
    document.getElementById('qw-hP').innerHTML = '';

    var groups = MODELS[dev];
    if (!groups || groups.length === 0) {
      c.innerHTML = '<div class="qw-empty"><p>Contact us for a quote on this device.</p><a href="/pages/contact" class="qw-btn-book">Get in touch</a></div>';
      return;
    }

    var w = document.createElement('div'); w.className = 'qw-m-groups';
    groups.forEach(function(g) {
      var ge = document.createElement('div'); ge.className = 'qw-m-group';
      var h = document.createElement('div'); h.className = 'qw-m-head';
      h.innerHTML = '<div><span class="qw-m-name">' + esc(g.group) + '</span><span class="qw-m-count">' + g.models.length + ' models</span></div><svg class="qw-m-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>';
      h.onclick = function() { ge.classList.toggle('open'); };
      ge.appendChild(h);

      var b = document.createElement('div'); b.className = 'qw-m-body';
      var l = document.createElement('div'); l.className = 'qw-m-list';
      g.models.forEach(function(m) {
        var it = document.createElement('div'); it.className = 'qw-m-item'; it.tabIndex = 0; it.setAttribute('role', 'button');
        it.innerHTML = '<span class="qw-mn">' + esc(m.name) + '</span>';
        it.setAttribute('data-handle', m.collectionHandle);
        it.onclick = function() { pickModel(m.name, m.collectionHandle, it); };
        it.onkeydown = function(e) { if (e.key === 'Enter') pickModel(m.name, m.collectionHandle, it); };
        l.appendChild(it);
      });
      b.appendChild(l); ge.appendChild(b); w.appendChild(ge);
    });
    c.appendChild(w);
    renderHelper(dev);
  }

  async function pickModel(name, handle, el) {
    S.model = name; S.collectionHandle = handle; S.fault = null; S.issue = null;
    document.querySelectorAll('.qw-m-item').forEach(function(c) { c.classList.remove('sel'); });
    if (el) el.classList.add('sel');

    /* Show loading */
    document.getElementById('qw-s3').querySelector('.qw-f-grid').innerHTML = '<div class="qw-loading"><div class="qw-spinner"></div><p>Loading repairs for ' + esc(name) + '...</p></div>';

    var products = await fetchCollection(handle);
    _repairsMap = buildRepairsMap(products);

    if (window.posthog) posthog.capture('wizard_step', { step: 3, device: S.device, model: S.model });

    if (S.preFault) {
      var pf = S.preFault; S.preFault = null; S.fault = pf;
      renderFaults(S.device);
      renderIssues(S.device, pf);
      go(4);
      return;
    }

    renderFaults(S.device);
    go(3);
  }

  /* =============================================
     MODEL HELPERS (iPhone visual guide + MacBook search)
