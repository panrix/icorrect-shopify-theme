    hT.onclick = function() { hP.classList.toggle('open'); };

    if (dev === 'iphone') renderIphoneVG(hP);
    else if (dev === 'macbook') renderMacbookHelper(hP);
    else renderGenericHelper(hP, dev);
  }

  function renderIphoneVG(panel) {
    var vgS = {};
