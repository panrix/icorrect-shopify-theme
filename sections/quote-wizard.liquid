  /* =============================================
     FETCH + DATA FUNCTIONS
     ============================================= */
  function deriveRepairTypeFromHandle(handle) {
    var keys = Object.keys(HANDLE_SUFFIX_MAP);
    keys.sort(function(a, b) { return b.length - a.length; });
    for (var i = 0; i < keys.length; i++) { if (handle.endsWith(keys[i])) return HANDLE_SUFFIX_MAP[keys[i]]; }
    return null;
  }

  async function fetchCollection(handle) {
    if (_collectionCache[handle]) return _collectionCache[handle];
    try {
      var res = await fetch('/collections/' + handle + '/products.json?limit=250');
      if (!res.ok) return [];
      var data = await res.json();
      _collectionCache[handle] = data.products;
      return data.products;
    } catch(e) { return []; }
  }

  function buildRepairsMap(products) {
    var map = {};
    for (var i = 0; i < products.length; i++) {
      var rt = deriveRepairTypeFromHandle(products[i].handle);
      if (rt) map[rt] = products[i];
    }
    return map;
  }

  async function fetchProduct(handle) {
    if (_productCache[handle]) return _productCache[handle];
    try {
      var res = await fetch('/products/' + handle + '.json');
      if (!res.ok) throw new Error('fail');
      var data = await res.json();
      _productCache[handle] = data.product;
      return data.product;
    } catch(e) {
      await new Promise(function(r) { setTimeout(r, 1000); });
      try {
        var res2 = await fetch('/products/' + handle + '.json');
        if (!res2.ok) return null;
        var data2 = await res2.json();
        _productCache[handle] = data2.product;
        return data2.product;
      } catch(e2) { return null; }
    }
  }

  /* =============================================
     FAULT/ISSUE FILTERING
     ============================================= */
  function getAvailableFaults(device, repairsMap) {
    var available = {};
    for (var rt in repairsMap) {
      var fault = REPAIR_TYPE_TO_FAULT[rt];
      if (fault && fault !== '_diagnostic') available[fault] = true;
    }
    available['Water Damage'] = true;
    available['Data Recovery'] = true;
    available['Other'] = true;
    return FAULTS[device].filter(function(f) { return available[f.v]; });
  }

  function getAvailableIssues(device, fault, repairsMap) {
    var issues = TS[device] && TS[device][fault];
    if (!issues) return [];
    return issues.filter(function(iss) {
      if (iss.route === 'contact' || iss.route === 'dismiss') return true;
      if (iss.route === 'diagnostic') return !!repairsMap['diagnostic'];
      return !!repairsMap[iss.repairType];
    });
  }

