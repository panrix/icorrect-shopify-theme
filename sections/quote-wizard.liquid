    var estimateRows = '';
    estimateRows += '<div class="qw-estimate-row"><span>Diagnostic</span><span>' + gbp.format(diagPrice) + '</span></div>';

    if (iss.likelyRepair && _repairsMap[iss.likelyRepair]) {
