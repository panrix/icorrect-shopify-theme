  min-height: 16px;
}
.quote-wizard .qw-form-error {
  font-size: 13px;
  color: #dc2626;
  padding: 10px 0;
  text-align: center;
}

/* Question form toggle */
.quote-wizard .qw-question-form {
  border-top: 1px solid var(--qw-line);
  padding-top: 16px;
  margin-top: 16px;
}

/* Success message */
.quote-wizard .qw-success {
  text-align: center;
  padding: 24px 16px;
}
.quote-wizard .qw-success p {
  font-size: 16px;
  font-weight: 600;
  color: var(--qw-green);
