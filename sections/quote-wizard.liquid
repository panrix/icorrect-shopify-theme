}
.quote-wizard .qw-btn-primary {
  background: var(--qw-accent);
  color: #fff;
}
.quote-wizard .qw-btn-primary:hover {
  background: var(--qw-accent-h);
  box-shadow: 0 4px 16px rgba(37,99,235,0.2);
  transform: translateY(-1px);
}
.quote-wizard .qw-btn-primary:active {
  transform: scale(0.98);
}
.quote-wizard .qw-btn-primary:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
