  color: var(--qw-dark);
}
.quote-wizard .qw-price-link {
  font-size: 14px;
  font-weight: 600;
  color: var(--qw-accent);
  text-decoration: none;
}
.quote-wizard .qw-price-link:hover {
  text-decoration: underline;
}

/* Likely repair */
.quote-wizard .qw-likely-repair {
  margin-bottom: 16px;
}
.quote-wizard .qw-likely-text {
  font-size: 13px;
  color: var(--qw-text-2);
  margin: 0;
  padding: 10px 14px;
  background: #fef9c3;
  border-radius: var(--qw-r-sm);
}

/* CTAs */
.quote-wizard .qw-ctas {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* Buttons */
.quote-wizard .qw-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12px 24px;
  border-radius: var(--qw-r-sm);
  font-family: inherit;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  transition: all var(--qw-ease);
  text-decoration: none;
  text-align: center;
