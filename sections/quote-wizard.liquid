              <span class="qw-hrs-d">Mon</span><span class="qw-hrs-t">{{ section.settings.hours_mon | default: '9am - 6pm' }}</span>
              <span class="qw-hrs-d">Tue</span><span class="qw-hrs-t">{{ section.settings.hours_tue | default: '9am - 6pm' }}</span>
