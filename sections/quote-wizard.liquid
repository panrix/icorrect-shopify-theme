<script>
window.WIZARD_CONTEXT = {
  pageType: "{{ template.name }}",
  collectionHandle: {{ collection.handle | default: '' | json }},
  productHandle: {{ product.handle | default: '' | json }},
  {%- if product -%}
    {%- comment -%}On product pages, collect ALL repair-prices collections so JS can find the model-specific one{%- endcomment -%}
    modelCollections: [
      {%- for col in product.collections -%}
        {%- if col.handle contains 'repair-prices' -%}
          {{ col.handle | json }},{%- endif -%}
      {%- endfor -%}
    ],
    device: {{ product.metafields.custom.wizard_device | default: '' | json }},
    fault: ""
  {%- elsif collection -%}
    device: {{ collection.metafields.custom.wizard_device | default: '' | json }},
    fault: {{ collection.metafields.custom.wizard_fault | default: '' | json }}
  {%- else -%}
    device: "",
    fault: ""
  {%- endif -%}
};
</script>

<!-- [1.7] Pre-fill for logged-in customers -->
{%- if customer -%}
<script>window.WIZARD_CUSTOMER = { name: {{ customer.name | json }}, email: {{ customer.email | json }} };</script>
{%- endif -%}

<!-- Service products (global) -->
{%- assign walk_in_prod = all_products['walk-in-service'] -%}
{%- assign mail_in_prod = all_products['mail-in-service'] -%}
<script>
window.WIZARD_CFG = {
  warrantyLabel: {{ section.settings.warranty_label | default: '2-year warranty' | json }},
  diagnosticTurnaround: {{ section.settings.diagnostic_turnaround | default: '2 working days' | json }},
  walkIn: {
    title: {{ walk_in_prod.title | default: 'Walk-in Service' | json }},
    price: {{ walk_in_prod.price | default: 0 | divided_by: 100.0 }},
    variantId: {{ walk_in_prod.selected_or_first_available_variant.id | default: 'null' }}
  },
  mailIn: {
    title: {{ mail_in_prod.title | default: 'Collection & Delivery' | json }},
    price: {{ mail_in_prod.price | default: 2000 | divided_by: 100.0 }},
    variantId: {{ mail_in_prod.selected_or_first_available_variant.id | default: 'null' }}
  }
};
</script>

<!-- HTML SKELETON -->
<div class="qw-section">
  <div class="qw-wrap">

    {%- if section.settings.show_map -%}
