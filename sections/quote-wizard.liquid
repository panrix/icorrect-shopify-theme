      estimateRows += '<div class="qw-estimate-row"><span>Should the logic board need repair</span><span>from ' + gbp.format(boardFloor) + '</span></div>';
    }

    var likelyHtml = estimateRows ? '<div class="qw-estimate">' + estimateRows + '</div>' : '';

    var serviceHtml = buildServiceCards();
    var totalHtml = diagPrice ? '<div class="qw-price-total"><span class="qw-price-total-label">Total</span><span class="qw-price-total-val" id="qwPriceTotal">' + gbp.format(diagPrice) + '</span></div>' : '';

    var badges = buildDiagnosticBadges(S.device);

    container.innerHTML = urgentHtml +
      '<div class="qw-res" id="qwResCard" data-base="' + diagPrice + '">' +
        '<div class="qw-res-top">' +
          '<div class="qw-res-badge qw-badge-amber"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>We need to take a look</div>' +
          '<h3 class="qw-res-h">Book a Diagnostic</h3>' +
          '<p class="qw-res-p">' + esc(iss.copy) + '</p>' +
          priceHtml +
          likelyHtml +
        '</div>' +
        '<div class="qw-svc">' + badges + '</div>' +
        '<div style="padding:0 24px 8px;">' + serviceHtml + '</div>' +
        totalHtml +
        '<div class="qw-res-cta">' +
          '<a href="/products/' + diagProduct.handle + '" class="qw-btn-book" id="qwBookBtn">Book a Diagnostic <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>' +
          '<button class="qw-btn-q" id="qwToggleCF"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>I have a question first</button>' +
          /* [4.6] Intercom chat link */
          '<a href="#" class="qw-btn-chat" id="qwIntercomBtn" style="display:none"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>Chat with us now</a>' +
        '</div>' +
        buildContactAccordion() +
      '</div>' +
      '<button class="qw-restart" id="qwRestart"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><path d="M1 4v6h6M23 20v-6h-6"/><path d="M20.49 9A9 9 0 105.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 013.51 15"/></svg> Start over</button>';

    /* Show Intercom button if available */
    var icBtn = document.getElementById('qwIntercomBtn');
    if (icBtn && window.Intercom) {
      icBtn.style.display = '';
      icBtn.onclick = function(e) { e.preventDefault(); Intercom('show'); };
    }

    wireOptCards(container);
    wireCFToggle(container);
    wireRestart(container);
    wireBookTracking(container);
    if (diagPrice) setupStickyCTA(gbp.format(diagPrice), '/products/' + diagProduct.handle);
  }

  /* ---- DISMISS CARD (dead-end, no form) ---- */
  function showDismissCard(iss, container) {
    container.innerHTML =
      '<div class="qw-res">' +
        '<div class="qw-res-top" style="padding-bottom:24px;">' +
          '<div class="qw-res-badge qw-badge-amber"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v2m0 4h.01M5.07 19h13.86c1.5 0 2.47-1.6 1.73-2.88L13.73 4.13c-.74-1.28-2.72-1.28-3.46 0L3.34 16.12C2.6 17.4 3.57 19 5.07 19z"/></svg>We can\'t help with this one</div>' +
          '<h3 class="qw-res-h">Contact Apple Support</h3>' +
          '<p class="qw-res-p">' + esc(iss.copy) + '</p>' +
          '<a href="https://support.apple.com" target="_blank" rel="noopener" class="qw-btn-book" style="max-width:280px;">Visit Apple Support <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/></svg></a>' +
        '</div>' +
      '</div>' +
      '<button class="qw-restart" id="qwRestart"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><path d="M1 4v6h6M23 20v-6h-6"/><path d="M20.49 9A9 9 0 105.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 013.51 15"/></svg> Start over</button>';
    wireRestart(container);
  }

  /* ---- CONTACT CARD ---- */
  function showContactCard(iss, container) {
    var urgentHtml = iss.urgent ? '<div class="qw-urgent" role="alert"><span>\u26A0\uFE0F Safety concern: stop using the device and don\'t charge it.</span></div>' : '';
    container.innerHTML = urgentHtml +
      '<div class="qw-res">' +
        '<div class="qw-res-top">' +
          '<div class="qw-res-badge qw-badge-blue"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>Let\'s chat about this</div>' +
          '<h3 class="qw-res-h">Get in Touch</h3>' +
          '<p class="qw-res-p">' + esc(iss.copy) + '</p>' +
        '</div>' +
        '<div class="qw-c-inner-open">' +
          buildContactSummary() +
          buildContactFormHTML('qwCFD', true) +
        '</div>' +
      '</div>' +
      '<button class="qw-restart" id="qwRestart"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><path d="M1 4v6h6M23 20v-6h-6"/><path d="M20.49 9A9 9 0 105.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 013.51 15"/></svg> Start over</button>';
    wireContactForm('qwCFD', 'contact');
    wireRestart(container);
  }

  /* ---- SHARED CONTACT FORM BUILDERS ---- */
  function buildContactSummary() {
    return '<div class="qw-c-sum"><strong>Device:</strong> ' + esc(DN[S.device] || '') + ' &bull; <strong>Model:</strong> ' + esc(S.model || 'N/A') + ' &bull; <strong>Fault:</strong> ' + esc(S.fault || 'N/A') + ' &bull; <strong>Issue:</strong> ' + esc(S.issue || 'N/A') + '</div>';
  }

  function buildContactFormHTML(prefix, visible) {
    var cust = CUST || {};
    return '<form class="qw-cf" id="' + prefix + 'Form" novalidate' + (visible ? '' : ' style="display:none"') + '>' +
      '<div class="qw-f-row two">' +
        '<div class="qw-f-grp"><label class="qw-f-lbl" for="' + prefix + 'N">Name<span class="qw-req">*</span></label><input class="qw-f-inp" type="text" id="' + prefix + 'N" placeholder="Full name" required value="' + esc(cust.name || '') + '"><span class="qw-f-err" id="' + prefix + 'NErr"></span></div>' +
        '<div class="qw-f-grp"><label class="qw-f-lbl" for="' + prefix + 'E">Email<span class="qw-req">*</span></label><input class="qw-f-inp" type="email" id="' + prefix + 'E" placeholder="you@email.com" required value="' + esc(cust.email || '') + '"><span class="qw-f-err" id="' + prefix + 'EErr"></span></div>' +
      '</div>' +
      '<div class="qw-f-row"><div class="qw-f-grp"><label class="qw-f-lbl" for="' + prefix + 'P">Phone<span class="qw-req">*</span></label><input class="qw-f-inp" type="tel" id="' + prefix + 'P" placeholder="+44 7000 000000" required><span class="qw-f-err" id="' + prefix + 'PErr"></span></div></div>' +
      '<div class="qw-f-row"><div class="qw-f-grp"><label class="qw-f-lbl" for="' + prefix + 'M">Your question</label><textarea class="qw-f-ta" id="' + prefix + 'M" placeholder="What do you need help with?"></textarea></div></div>' +
      '<button type="submit" class="qw-f-sub" disabled>Send question</button>' +
    '</form>' +
    '<div class="qw-f-ok" id="' + prefix + 'Ok"><h3>Sent!</h3><p>We\'ll be in touch shortly.</p></div>';
  }

  function buildContactAccordion() {
    return '<div class="qw-c-acc" id="qwCAcc">' +
      '<div class="qw-c-inner">' + buildContactSummary() + buildContactFormHTML('qwCFA', true) + '</div>' +
    '</div>';
  }

  /* [4.2] Inline validation */
  function wireContactForm(prefix, source) {
    var form = document.getElementById(prefix + 'Form');
    if (!form || form._wired) return;
    form._wired = true;
    var nIn = document.getElementById(prefix + 'N');
    var eIn = document.getElementById(prefix + 'E');
    var pIn = document.getElementById(prefix + 'P');
    var nErr = document.getElementById(prefix + 'NErr');
    var eErr = document.getElementById(prefix + 'EErr');
    var pErr = document.getElementById(prefix + 'PErr');
    var sub = form.querySelector('.qw-f-sub');

    function validate() {
      var valid = true;
      if (!nIn.value || nIn.value.trim().length < 2) { nErr.textContent = 'Please enter your name'; valid = false; } else { nErr.textContent = ''; }
      var ev = (eIn.value || '').trim();
      if (!ev || ev.indexOf('@') === -1 || ev.indexOf('.') === -1) { eErr.textContent = 'Please enter a valid email'; valid = false; } else { eErr.textContent = ''; }
      var digits = (pIn.value || '').replace(/\D/g, '');
      if (digits.length < 8) { pErr.textContent = 'Please enter a valid phone number'; valid = false; } else { pErr.textContent = ''; }
      sub.disabled = !valid;
      return valid;
    }
    nIn.addEventListener('input', validate);
    eIn.addEventListener('input', validate);
    pIn.addEventListener('input', validate);
    /* Pre-validate if pre-filled */
    if (nIn.value || eIn.value) validate();

    form.onsubmit = function(e) {
      e.preventDefault();
      if (!validate()) return;
      sub.disabled = true; sub.textContent = 'Sending...';
      fetch('https://icorrect.app.n8n.cloud/workflow/tNQphRiUo0L8SdBn', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          source: 'quote-wizard-' + source, device: S.device || '', model: S.model || '',
          fault: S.fault || '', issue: S.issue || '', route: source,
          name: nIn.value.trim(), email: eIn.value.trim(), phone: pIn.value.trim(),
          message: (document.getElementById(prefix + 'M').value || '').trim(),
          url: window.location.href, timestamp: new Date().toISOString()
        })
      }).then(function(res) {
        if (res.ok) {
          form.style.display = 'none';
          var ok = document.getElementById(prefix + 'Ok');
          if (ok) ok.classList.add('show');
          if (window.posthog) posthog.capture('wizard_conversion', { action: source + '_submit', device: S.device, model: S.model, fault: S.fault, issue: S.issue });
        } else { sub.disabled = false; sub.textContent = 'Send question'; }
      }).catch(function() { sub.disabled = false; sub.textContent = 'Send question'; });
    };
  }

  /* ---- WIRING HELPERS ---- */
  function wireOptCards(container) {
    container.querySelectorAll('.qw-opt-card').forEach(function(card) {
      wireA11y(card, card.querySelector('.qw-opt-name') ? card.querySelector('.qw-opt-name').textContent : '');
      card.onclick = function() {
        var resCard = document.getElementById('qwResCard');
        if (!resCard) return;
        var base = parseFloat(resCard.dataset.base || 0);
        var group = card.dataset.opt;
        card.parentNode.querySelectorAll('.qw-opt-card[data-opt="' + group + '"]').forEach(function(c) { c.classList.remove('sel'); });
        card.classList.add('sel');
        var total = base;
        resCard.querySelectorAll('.qw-opt-card.sel').forEach(function(c) { total += parseFloat(c.dataset.add || 0); });
        var totalEl = document.getElementById('qwPriceTotal');
        if (totalEl) totalEl.textContent = gbp.format(total);
        /* Update sticky CTA price too */
        var stickyPrice = document.querySelector('.qw-sticky-price');
        if (stickyPrice) stickyPrice.textContent = gbp.format(total);
      };
    });
  }

  function wireCFToggle(container) {
    var toggle = container.querySelector('#qwToggleCF');
    if (!toggle) return;
    toggle.onclick = function() {
      var acc = document.getElementById('qwCAcc');
      if (!acc) return;
      acc.classList.toggle('open');
      if (acc.classList.contains('open')) {
        wireContactForm('qwCFA', 'question');
        scrollToEl(acc, 200);
      }
    };
  }

  function wireRestart(container) {
    var btn = container.querySelector('#qwRestart');
    if (btn) btn.onclick = function() { reset(); };
  }

  function wireBookTracking(container) {
    var btn = container.querySelector('#qwBookBtn');
    if (btn) btn.addEventListener('click', function() {
      if (window.posthog) posthog.capture('wizard_conversion', { action: 'book_repair', device: S.device, model: S.model, fault: S.fault, issue: S.issue });
    });
  }

  /* =============================================
     [5.1] STICKY CTA ON MOBILE
     ============================================= */
  var _stickyObserver = null;
  function setupStickyCTA(price, url) {
    var sticky = document.getElementById('qw-sticky-cta');
    if (!sticky) return;
    sticky.innerHTML = '<span class="qw-sticky-price">' + price + '</span><a href="' + url + '" class="qw-sticky-book">Book now</a>';

    var cta = document.querySelector('.qw-res-cta');
    if (!cta || !('IntersectionObserver' in window)) return;
    if (_stickyObserver) _stickyObserver.disconnect();
    _stickyObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        sticky.classList.toggle('show', !entry.isIntersecting);
      });
    }, { threshold: 0 });
    _stickyObserver.observe(cta);
  }

  function destroyStickyCTA() {
    if (_stickyObserver) { _stickyObserver.disconnect(); _stickyObserver = null; }
    var sticky = document.getElementById('qw-sticky-cta');
    if (sticky) { sticky.classList.remove('show'); sticky.innerHTML = ''; }
  }

  /* =============================================
     RESET
     ============================================= */
  function reset() {
    S.device = null; S.model = null; S.fault = null; S.issue = null; S.step = 1; S.collectionHandle = null; _repairsMap = {};
    document.querySelectorAll('.qw-dev').forEach(function(c) { c.classList.remove('sel'); });
    var rP = document.getElementById('qw-rP');
    if (rP) { rP.style.display = 'none'; rP.innerHTML = ''; }
    destroyStickyCTA();
    go(1);
  }

  /* =============================================
     BACK BUTTONS
     ============================================= */
  var b2 = document.getElementById('qw-back2'); if (b2) b2.onclick = function() { go(1); };
  var b3 = document.getElementById('qw-back3'); if (b3) b3.onclick = function() { go(2); };
  var b4 = document.getElementById('qw-back4'); if (b4) b4.onclick = function() { go(3); };

  /* =============================================
     [1.5] OPEN/CLOSED INDICATOR
     ============================================= */
  function updateOpenClosed() {
    var badge = document.getElementById('qw-open-badge');
    if (!badge) return;
    try {
      var now = new Date();
      var london = new Date(now.toLocaleString('en-GB', { timeZone: 'Europe/London' }));
      var day = london.getDay();
      var hour = london.getHours();
      var openHour = (day === 5) ? 10 : 9;
      var isOpen = day >= 1 && day <= 5 && hour >= openHour && hour < 18;
      badge.innerHTML = isOpen
        ? '<span class="qw-open-dot qw-open-yes"></span>Open now'
        : '<span class="qw-open-dot qw-open-no"></span>Closed';
      badge.className = isOpen ? 'qw-open-badge open' : 'qw-open-badge closed';
    } catch(e) {}
  }

  /* =============================================
     PRE-FILL SYSTEM
     ============================================= */
  function findModelByCollection(handle) {
    var devices = ['macbook', 'iphone', 'ipad', 'watch'];
    for (var d = 0; d < devices.length; d++) {
      var groups = MODELS[devices[d]];
      if (!groups) continue;
      for (var g = 0; g < groups.length; g++) {
        for (var m = 0; m < groups[g].models.length; m++) {
          if (groups[g].models[m].collectionHandle === handle) return { device: devices[d], model: groups[g].models[m] };
        }
      }
    }
    return null;
  }

  function initPrefill() {
    var ctx = CONTEXT;
    _suppressScroll = true; /* Don't scroll during init - page should load from top */

    /* CASE 1: Product page — pre-fill device + model, derive fault from handle */
    if (ctx && ctx.productHandle) {
      var modelCol = ctx.modelCollection || ctx.collectionHandle || '';
      if (modelCol) {
        var modelMatch = findModelByCollection(modelCol);
        if (modelMatch) {
          /* Derive repair type from product handle */
          var rt = deriveRepairTypeFromHandle(ctx.productHandle);
          var faultName = rt ? REPAIR_TYPE_TO_FAULT[rt] : null;
          S.device = modelMatch.device;
          if (faultName && faultName !== '_diagnostic') S.preFault = faultName;
          renderDevices();
          pickModel(modelMatch.model.name, modelMatch.model.collectionHandle, null).then(function() {
            _suppressScroll = false;
          });
          return;
        }
      }
      /* Product page but can't find model — try device at least */
      if (ctx.device) {
        S.device = ctx.device;
        renderDevices();
        renderModels(ctx.device);
        go(2);
        _suppressScroll = false;
        return;
      }
    }

    /* CASE 2: Collection page — pre-fill device + model */
    if (ctx && ctx.collectionHandle) {
      var match = findModelByCollection(ctx.collectionHandle);
      if (match) {
        S.device = match.device;
        renderDevices();
        pickModel(match.model.name, match.model.collectionHandle, null).then(function() {
          _suppressScroll = false;
        });
        return;
      }
    }

    /* CASE 3: Device context from metafield */
    if (ctx && ctx.device) {
      S.device = ctx.device;
      if (ctx.fault) S.preFault = ctx.fault;
      renderDevices();
      renderModels(ctx.device);
      go(2);
      _suppressScroll = false;
      return;
    }

    /* CASE 4: No context — start fresh */
    renderDevices();
    go(1);
    _suppressScroll = false;
  }

  /* =============================================
     BROWSER BACK + [4.9] POSTHOG DROP-OFF
     ============================================= */
  window.addEventListener('popstate', function(e) {
    if (e.state && typeof e.state.step === 'number') {
      S.device = e.state.device || null;
      S.model = e.state.model || null;
      S.fault = e.state.fault || null;
      S.issue = null;
      document.querySelectorAll('.qw-step').forEach(function(el) { el.classList.remove('on'); });
      var stepEl = document.getElementById('qw-s' + e.state.step);
      if (stepEl) stepEl.classList.add('on');
      updateProg(e.state.step);
      updateCrumb();
    }
  });

  window.addEventListener('beforeunload', function() {
    if (S.step > 1 && !S.issue && window.posthog) {
      posthog.capture('wizard_abandoned', { step: S.step, device: S.device, model: S.model, fault: S.fault, duration: Date.now() - _stepStartTime });
    }
  });

  /* =============================================
     INIT
     ============================================= */
  wireProgDots();
  updateOpenClosed();
  initPrefill();

})();
</script>

<!-- CSS -->
<style>
/* ========================================
   VARIABLES & BASE
   ======================================== */
.qw-section {
  --qw-dark:#0f0f14;--qw-text:#1d1d2b;--qw-text-2:#4a4a5c;--qw-text-3:#8c8c9e;
  --qw-accent:#2563eb;--qw-accent-h:#1d4ed8;--qw-accent-bg:#eff4ff;
  --qw-bg:#f6f7f9;--qw-white:#ffffff;--qw-line:#e4e6ec;--qw-line-h:#cdd0da;
  --qw-green:#059669;--qw-green-bg:#ecfdf5;--qw-amber:#D97706;--qw-amber-bg:#fffbeb;
  --qw-blue:#2563eb;--qw-blue-bg:#eff4ff;
  --qw-r-sm:8px;--qw-r-md:12px;--qw-r-lg:16px;
  --qw-sh-1:0 1px 2px rgba(15,15,20,0.04);--qw-sh-2:0 4px 12px rgba(15,15,20,0.07);
  --qw-sh-focus:0 0 0 3px rgba(37,99,235,0.12);--qw-ease:0.2s cubic-bezier(0.4,0,0.2,1);
  font-family:'DM Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
  color:var(--qw-text);-webkit-font-smoothing:antialiased;letter-spacing:-0.015em;line-height:1.5;
  width:100%;padding:40px 16px;
}
@media(min-width:1024px){.qw-section{padding:56px 24px;}}

/* LAYOUT */
.qw-wrap{max-width:1360px;margin:0 auto;display:flex;flex-direction:column;gap:32px;}
@media(min-width:1024px){.qw-wrap{flex-direction:row;align-items:flex-start;gap:52px;}.qw-info{width:44%;flex-shrink:0;position:sticky;top:28px;}.qw-wizard{width:56%;}}
/* [1.2] Mobile: wizard above map */
@media(max-width:1023px){.qw-info{order:2;}.qw-wizard{order:1;}}

/* LEFT: MAP + DETAILS */
.qw-info{display:flex;flex-direction:column;gap:16px;}
.qw-map{width:100%;height:240px;border-radius:var(--qw-r-lg);overflow:hidden;border:1px solid var(--qw-line);box-shadow:var(--qw-sh-1);}
@media(min-width:1024px){.qw-map{height:auto;aspect-ratio:4/3;}}
.qw-map iframe{width:100%;height:100%;border:0;display:block;}
.qw-card{background:var(--qw-white);border:1px solid var(--qw-line);border-radius:var(--qw-r-lg);overflow:hidden;}
.qw-card-grid{display:grid;grid-template-columns:1fr;}
@media(min-width:560px){.qw-card-grid{grid-template-columns:1fr 1fr;}.qw-card-left{border-right:1px solid var(--qw-line);border-bottom:none;}}
.qw-card-left{border-bottom:1px solid var(--qw-line);}
.qw-card-col{padding:20px;display:flex;flex-direction:column;gap:14px;}
.qw-d-group{display:flex;flex-direction:column;gap:5px;}
.qw-d-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(--qw-text-3);display:flex;align-items:center;gap:5px;margin:0;}
.qw-d-label svg{width:14px;height:14px;color:var(--qw-accent);flex-shrink:0;}
.qw-d-val{font-size:14px;font-weight:500;line-height:1.5;color:var(--qw-text);text-decoration:none;display:block;}
a.qw-d-val:hover{color:var(--qw-accent);}
.qw-hrs{display:grid;grid-template-columns:80px 1fr;gap:4px 10px;font-size:13px;}
.qw-hrs-d{color:var(--qw-text-3);font-weight:500;}.qw-hrs-t{color:var(--qw-text);font-weight:600;}.qw-hrs-c{color:var(--qw-accent);}
/* [1.5] Open/closed indicator */
.qw-open-badge{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;margin-left:6px;}
.qw-open-badge.open{color:var(--qw-green);}.qw-open-badge.closed{color:var(--qw-text-3);}
.qw-open-dot{display:inline-block;width:6px;height:6px;border-radius:50%;margin-right:3px;vertical-align:middle;}
.qw-open-yes{background:var(--qw-green);}.qw-open-no{background:var(--qw-text-3);}

/* WIZARD */
.qw-wizard{display:flex;flex-direction:column;}
.qw-head{margin-bottom:28px;}
.qw-title{font-size:clamp(28px,4.5vw,48px);font-weight:700;line-height:1.08;letter-spacing:-0.035em;color:var(--qw-dark);margin:0 0 8px;}
.qw-sub{font-size:clamp(14px,1.1vw,16px);font-weight:400;line-height:1.55;color:var(--qw-text-2);margin:0;}
/* STEP INDICATOR */
.qw-prog{display:flex;align-items:center;margin-bottom:24px;}
.qw-prog-s{display:flex;align-items:center;gap:6px;flex:1;cursor:pointer;}
.qw-prog-dot{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;transition:all var(--qw-ease);border:2px solid var(--qw-line);background:var(--qw-white);color:var(--qw-text-3);}
.qw-prog-s.on .qw-prog-dot{background:var(--qw-accent);border-color:var(--qw-accent);color:#fff;box-shadow:0 2px 8px rgba(37,99,235,0.2);}
.qw-prog-s.done .qw-prog-dot{background:var(--qw-dark);border-color:var(--qw-dark);color:#fff;}
.qw-prog-lbl{font-size:11px;font-weight:600;color:var(--qw-text-3);display:none;white-space:nowrap;}
.qw-prog-s.on .qw-prog-lbl{color:var(--qw-accent);display:block;}
.qw-prog-s.done .qw-prog-lbl{color:var(--qw-dark);display:block;}
@media(min-width:560px){.qw-prog-lbl{display:block;}}
.qw-prog-line{flex:1;height:2px;background:var(--qw-line-h);margin:0 8px;border-radius:2px;position:relative;overflow:hidden;min-width:20px;}
.qw-prog-line::after{content:'';position:absolute;left:0;top:0;height:100%;width:0;background:var(--qw-dark);border-radius:2px;transition:width 0.4s cubic-bezier(0.4,0,0.2,1);}
.qw-prog-s.done .qw-prog-line::after{width:100%;}
.qw-prog-s.on .qw-prog-line::after{width:0;}
.qw-prog-s:last-child .qw-prog-line{display:none;}

/* [4.3] Breadcrumb */
.qw-crumb{display:flex;align-items:center;flex-wrap:wrap;gap:2px;margin-bottom:16px;min-height:20px;}
.qw-crumb:empty{margin-bottom:0;min-height:0;}
.qw-crumb-btn{background:none;border:none;font-family:inherit;font-size:12px;font-weight:500;color:var(--qw-accent);cursor:pointer;padding:2px 4px;border-radius:4px;transition:background var(--qw-ease);max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.qw-crumb-btn:hover{background:var(--qw-accent-bg);}
.qw-crumb-sep{color:var(--qw-text-3);font-size:12px;margin:0 1px;}

/* STEPS */
.qw-step{display:none;animation:qwFadeUp .28s ease-out;}
.qw-step.on{display:block;}
@keyframes qwFadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.qw-s-title{font-size:clamp(18px,2.2vw,26px);font-weight:700;letter-spacing:-0.025em;line-height:1.12;margin:0 0 4px;color:var(--qw-dark);}
.qw-s-sub{font-size:14px;color:var(--qw-text-2);margin:0 0 20px;line-height:1.5;}
.qw-back{display:inline-flex;align-items:center;gap:5px;background:none;border:none;font-family:inherit;font-size:13px;font-weight:600;color:var(--qw-text-3);cursor:pointer;padding:6px 0;margin-bottom:14px;transition:color var(--qw-ease);}
.qw-back:hover{color:var(--qw-text);}
.qw-back svg{width:15px;height:15px;}

/* DEVICE GRID */
.qw-dev-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;}
@media(min-width:480px){.qw-dev-grid{grid-template-columns:repeat(3,1fr);}}
@media(min-width:680px){.qw-dev-grid{grid-template-columns:repeat(4,1fr);}}
.qw-dev{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;padding:20px 10px;background:var(--qw-white);border:2px solid var(--qw-line);border-radius:var(--qw-r-md);cursor:pointer;transition:all var(--qw-ease);min-height:100px;text-align:center;-webkit-tap-highlight-color:transparent;}
.qw-dev:hover{border-color:var(--qw-line-h);box-shadow:var(--qw-sh-2);transform:translateY(-2px);}
.qw-dev:active{transform:scale(0.97);}
/* [5.3] Selection animation */
.qw-dev.sel,.qw-f-card.sel,.qw-t-card.sel,.qw-opt-card.sel{animation:qwPulse 0.2s ease-out;}
@keyframes qwPulse{0%{transform:scale(1);}50%{transform:scale(0.96);}100%{transform:scale(1);}}
.qw-dev.sel{border-color:var(--qw-accent);background:var(--qw-accent-bg);box-shadow:var(--qw-sh-focus);}
.qw-dev:focus-visible{outline:none;box-shadow:var(--qw-sh-focus);}
.qw-dev-ico{width:32px;height:32px;display:flex;align-items:center;justify-content:center;}
.qw-dev-ico svg{width:100%;height:100%;color:var(--qw-text);}
.qw-dev.sel .qw-dev-ico svg{color:var(--qw-accent);}
.qw-dev-lbl{font-size:13px;font-weight:600;}

/* MODEL GROUPS */
.qw-m-groups{display:flex;flex-direction:column;gap:6px;}
.qw-m-group{border:1px solid var(--qw-line);border-radius:var(--qw-r-md);overflow:hidden;background:var(--qw-white);}
.qw-m-head{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;cursor:pointer;user-select:none;transition:background var(--qw-ease);-webkit-tap-highlight-color:transparent;}
.qw-m-head:hover{background:#fafbfc;}.qw-m-head:active{background:#f4f5f7;}
.qw-m-name{font-size:15px;font-weight:700;color:var(--qw-text);letter-spacing:-0.02em;}
.qw-m-count{font-size:12px;color:var(--qw-text-3);font-weight:500;margin-top:1px;display:block;}
.qw-m-chev{width:18px;height:18px;color:var(--qw-text-3);transition:transform .25s ease;flex-shrink:0;}
.qw-m-group.open .qw-m-chev{transform:rotate(180deg);}
.qw-m-body{max-height:0;overflow:hidden;transition:max-height .35s ease;}
.qw-m-group.open .qw-m-body{max-height:3000px;}
.qw-m-list{padding:0 14px 14px;display:flex;flex-direction:column;gap:2px;}
.qw-m-item{display:flex;align-items:center;padding:12px 14px;border-radius:var(--qw-r-sm);cursor:pointer;transition:all var(--qw-ease);-webkit-tap-highlight-color:transparent;}
.qw-m-item:hover{background:#f5f6fa;}.qw-m-item:active{background:#eef0f5;}
.qw-m-item.sel{background:var(--qw-accent-bg);outline:1.5px solid var(--qw-accent);}
.qw-mn{font-size:14px;font-weight:600;color:var(--qw-text);line-height:1.3;flex:1;min-width:0;}

/* HELPER */
.qw-help-trig{display:flex;align-items:center;gap:7px;padding:10px 0;margin-top:14px;background:none;border:none;font-family:inherit;font-size:13px;font-weight:600;color:var(--qw-blue);cursor:pointer;-webkit-tap-highlight-color:transparent;}
.qw-help-trig:hover{text-decoration:underline;}
.qw-help-trig svg{width:16px;height:16px;flex-shrink:0;}
.qw-help-panel{max-height:0;overflow:hidden;transition:max-height .4s ease,opacity .3s ease;opacity:0;margin-top:6px;}
.qw-help-panel.open{max-height:900px;opacity:1;}
.qw-help-card{background:var(--qw-white);border:1px solid var(--qw-line);border-radius:var(--qw-r-md);overflow:hidden;}
.qw-help-body{padding:18px;}
.qw-help-img{width:100%;border-radius:var(--qw-r-sm);margin-bottom:14px;}
.qw-help-inst{font-size:13px;color:var(--qw-text-2);line-height:1.55;margin-bottom:14px;}
.qw-help-inst code{background:#f0f1f5;padding:2px 5px;border-radius:3px;font-size:12px;font-weight:600;color:var(--qw-text);}
.qw-help-row{display:flex;gap:8px;margin-bottom:10px;}
.qw-help-input{flex:1;padding:10px 12px;border:1px solid var(--qw-line);border-radius:var(--qw-r-sm);font-size:14px;font-family:inherit;}
.qw-help-input:focus{outline:none;border-color:var(--qw-blue);box-shadow:0 0 0 2px rgba(37,99,235,0.1);}
.qw-help-results{max-height:180px;overflow-y:auto;}
.qw-help-hit{display:flex;align-items:center;justify-content:space-between;padding:9px 10px;border-bottom:1px solid #f0f1f5;cursor:pointer;transition:background var(--qw-ease);font-size:13px;}
.qw-help-hit:hover{background:var(--qw-blue-bg);}.qw-help-hit:last-child{border-bottom:none;}
.qw-hn{font-weight:700;color:var(--qw-text);font-family:monospace;font-size:12px;}
.qw-hm{color:var(--qw-text-2);font-weight:500;flex:1;margin:0 8px;}
.qw-hs{font-size:11px;font-weight:700;color:var(--qw-blue);flex-shrink:0;}
.qw-help-close{display:flex;align-items:center;justify-content:center;padding:10px;background:#f5f6fa;border:none;font-family:inherit;font-size:12px;font-weight:600;color:var(--qw-text-3);cursor:pointer;width:100%;transition:all var(--qw-ease);}
.qw-help-close:hover{background:#eef0f4;color:var(--qw-text);}

/* VG WIZARD */
.qw-vg-step{display:none;padding:20px;animation:qwFadeUp .25s ease-out;}.qw-vg-step.on{display:block;}
.qw-vg-title{font-size:16px;font-weight:700;color:var(--qw-text);margin-bottom:2px;text-align:center;}
.qw-vg-sub{font-size:13px;color:var(--qw-text-3);margin-bottom:16px;text-align:center;}
.qw-vg-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:12px;justify-items:center;max-width:480px;margin:0 auto;}
@media(max-width:479px){.qw-vg-grid{grid-template-columns:repeat(2,1fr);max-width:100%;}}
.qw-vg-opt{background:var(--qw-white);border:2px solid var(--qw-line);border-radius:var(--qw-r-md);padding:14px 10px;cursor:pointer;text-align:center;transition:all var(--qw-ease);width:100%;display:flex;flex-direction:column;align-items:center;gap:8px;-webkit-tap-highlight-color:transparent;box-sizing:border-box;}
.qw-vg-opt:hover{border-color:var(--qw-blue);transform:scale(1.03);}
.qw-vg-opt:active{transform:scale(0.97);}
.qw-vg-opt img,.qw-vg-img{max-width:80px;max-height:70px;object-fit:contain;}
.qw-vg-lbl{font-size:12px;font-weight:600;color:var(--qw-text);line-height:1.3;}
.qw-vg-back{display:inline-flex;align-items:center;gap:4px;background:none;border:none;font-family:inherit;font-size:12px;font-weight:600;color:var(--qw-text-3);cursor:pointer;margin-bottom:12px;}
.qw-vg-back:hover{color:var(--qw-text);}
.qw-vg-result{text-align:center;padding:20px;}
.qw-vg-result-name{font-size:18px;font-weight:700;margin-bottom:14px;}
.qw-vg-btn{padding:10px 20px;border-radius:20px;border:none;font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;margin:0 4px;}
.qw-vg-btn-p{background:var(--qw-blue);color:#fff;}.qw-vg-btn-s{background:#f0f1f5;color:var(--qw-text-2);}

/* FAULT CARDS */
.qw-f-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;}
@media(min-width:560px){.qw-f-grid{grid-template-columns:repeat(3,1fr);}}
@media(min-width:720px){.qw-f-grid{grid-template-columns:repeat(4,1fr);}}
.qw-f-card{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;padding:18px 8px;background:var(--qw-white);border:2px solid var(--qw-line);border-radius:var(--qw-r-md);cursor:pointer;transition:all var(--qw-ease);text-align:center;min-height:90px;-webkit-tap-highlight-color:transparent;}
.qw-f-card:hover{border-color:var(--qw-line-h);box-shadow:var(--qw-sh-2);transform:translateY(-1px);}
.qw-f-card:active{transform:scale(0.97);}
.qw-f-card.sel{border-color:var(--qw-accent);background:var(--qw-accent-bg);box-shadow:var(--qw-sh-focus);}
.qw-f-ico{width:24px;height:24px;color:var(--qw-text-2);transition:color var(--qw-ease);}
.qw-f-ico svg{width:100%;height:100%;}
.qw-f-card.sel .qw-f-ico{color:var(--qw-accent);}
.qw-f-lbl{font-size:12px;font-weight:600;line-height:1.3;}

/* ISSUE CARDS */
.qw-t-grid{display:grid;grid-template-columns:1fr;gap:8px;}
@media(min-width:560px){.qw-t-grid{grid-template-columns:repeat(2,1fr);}}
.qw-t-card{display:flex;align-items:center;gap:12px;padding:16px 18px;background:var(--qw-white);border:2px solid var(--qw-line);border-radius:var(--qw-r-md);cursor:pointer;transition:all var(--qw-ease);-webkit-tap-highlight-color:transparent;}
.qw-t-card:hover{border-color:var(--qw-line-h);box-shadow:var(--qw-sh-1);}
.qw-t-card:active{transform:scale(0.98);}
.qw-t-card.sel{border-color:var(--qw-accent);background:var(--qw-accent-bg);}
.qw-tw{width:36px;height:36px;border-radius:8px;background:#f0f1f5;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.qw-t-card.sel .qw-tw{background:rgba(37,99,235,0.08);}
.qw-tw svg{width:18px;height:18px;color:var(--qw-text-2);}
.qw-t-card.sel .qw-tw svg{color:var(--qw-accent);}
.qw-tt{font-size:14px;font-weight:600;line-height:1.3;}

/* RESOLUTION CARD */
.qw-res{background:var(--qw-white);border:1px solid var(--qw-line);border-radius:var(--qw-r-lg);overflow:hidden;}
.qw-res-top{padding:24px 24px 0;}
/* [5.5] Staggered entrance */
.qw-res-top > *{opacity:0;animation:qwFadeUp 0.3s ease-out forwards;}
.qw-res-top > *:nth-child(1){animation-delay:0s;}.qw-res-top > *:nth-child(2){animation-delay:0.06s;}
.qw-res-top > *:nth-child(3){animation-delay:0.12s;}.qw-res-top > *:nth-child(4){animation-delay:0.18s;}
.qw-res-top > *:nth-child(5){animation-delay:0.24s;}.qw-res-top > *:nth-child(6){animation-delay:0.3s;}
.qw-res-badge{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;padding:5px 10px;border-radius:100px;margin-bottom:14px;}
.qw-res-badge svg{width:13px;height:13px;}
.qw-badge-green{background:var(--qw-green-bg);color:var(--qw-green);}
.qw-badge-amber{background:var(--qw-amber-bg);color:var(--qw-amber);}
.qw-badge-blue{background:var(--qw-blue-bg);color:var(--qw-blue);}
.qw-res-h{font-size:20px;font-weight:700;letter-spacing:-0.025em;line-height:1.2;margin:0 0 6px;color:var(--qw-dark);}
.qw-res-p{font-size:14px;color:var(--qw-text-2);line-height:1.55;margin:0 0 20px;max-width:480px;}

/* Dustgate images */
.qw-dustgate-imgs{display:flex;gap:10px;margin-bottom:20px;}
.qw-dustgate-imgs img{flex:1;min-width:0;height:120px;object-fit:cover;border-radius:var(--qw-r-sm);border:1px solid var(--qw-line);}

/* Pricing */
.qw-price-from{font-size:13px;color:var(--qw-text-3);font-weight:500;margin-bottom:4px;}
.qw-price-big{font-size:36px;font-weight:700;letter-spacing:-0.03em;line-height:1;color:var(--qw-dark);margin-bottom:20px;}

/* [6.1] Diagnostic estimate */
.qw-estimate{background:#f8f9fb;border-radius:var(--qw-r-sm);padding:14px 16px;margin-bottom:20px;border:1px solid var(--qw-line);}
.qw-estimate-row{display:flex;justify-content:space-between;font-size:13px;color:var(--qw-text-2);padding:4px 0;}

/* Service badges */
.qw-svc{padding:0 24px;margin-bottom:2px;}
.qw-svc-r{display:flex;align-items:center;padding:9px 0;border-bottom:1px solid #f0f1f5;}
.qw-svc-r:last-child{border-bottom:none;}
.qw-svc-i{width:18px;height:18px;color:var(--qw-accent);margin-right:10px;flex-shrink:0;}.qw-svc-i svg{width:100%;height:100%;}
.qw-svc-l{width:90px;font-size:12px;font-weight:500;color:var(--qw-text-3);flex-shrink:0;}
.qw-svc-v{font-size:13px;font-weight:600;}

/* Option cards */
.qw-opt-section{margin-bottom:18px;}
.qw-opt-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--qw-text-3);margin-bottom:8px;padding:0 2px;}
.qw-opt-row{display:flex;gap:8px;flex-wrap:wrap;}
/* [5.2] Stack on narrow screens */
@media(max-width:479px){.qw-opt-row{flex-direction:column;}.qw-opt-card{min-width:100% !important;}}
.qw-opt-card{flex:1;min-width:0;padding:14px;background:var(--qw-white);border:2px solid var(--qw-line);border-radius:var(--qw-r-md);cursor:pointer;transition:all var(--qw-ease);-webkit-tap-highlight-color:transparent;position:relative;}
.qw-opt-card:hover{border-color:var(--qw-line-h);}
.qw-opt-card.sel{border-color:var(--qw-accent);background:var(--qw-accent-bg);}
.qw-opt-name{font-size:13px;font-weight:700;color:var(--qw-text);margin-bottom:2px;}
.qw-opt-meta{font-size:12px;color:var(--qw-text-3);font-weight:500;}
.qw-opt-price{font-size:14px;font-weight:700;color:var(--qw-text);margin-top:6px;}
.qw-opt-price.free{color:var(--qw-green);}
.qw-pop-tag{position:absolute;top:-8px;right:10px;background:var(--qw-dark);color:#fff;font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px;letter-spacing:0.03em;}

/* Price total */
.qw-price-total{display:flex;align-items:baseline;justify-content:space-between;padding:16px 0;margin:0 24px;border-top:1px solid var(--qw-line);}
.qw-price-total-label{font-size:14px;font-weight:600;color:var(--qw-text-2);}
.qw-price-total-val{font-size:28px;font-weight:700;letter-spacing:-0.02em;color:var(--qw-dark);}

/* CTAs */
.qw-res-cta{padding:16px 24px 24px;display:flex;flex-direction:column;gap:10px;}
.qw-btn-book{display:flex;align-items:center;justify-content:center;gap:7px;padding:14px 28px;background:var(--qw-accent);color:#fff;border:none;border-radius:var(--qw-r-sm);font-family:inherit;font-size:15px;font-weight:700;cursor:pointer;transition:all var(--qw-ease);text-decoration:none;letter-spacing:-0.01em;width:100%;}
.qw-btn-book:hover{background:var(--qw-accent-h);box-shadow:0 4px 16px rgba(37,99,235,0.2);transform:translateY(-1px);}
.qw-btn-book:active{transform:scale(0.98);}
.qw-btn-book svg{width:16px;height:16px;}
.qw-btn-q{display:flex;align-items:center;justify-content:center;gap:6px;padding:12px 24px;background:transparent;color:var(--qw-text-2);border:2px solid var(--qw-line);border-radius:var(--qw-r-sm);font-family:inherit;font-size:14px;font-weight:600;cursor:pointer;transition:all var(--qw-ease);width:100%;}
.qw-btn-q:hover{border-color:var(--qw-line-h);background:#fafbfc;color:var(--qw-text);}
/* [4.6] Intercom chat link */
.qw-btn-chat{display:flex;align-items:center;justify-content:center;gap:6px;padding:10px;background:none;border:none;font-family:inherit;font-size:13px;font-weight:600;color:var(--qw-accent);cursor:pointer;text-decoration:none;}
.qw-btn-chat:hover{text-decoration:underline;}

/* Contact accordion */
.qw-c-acc{max-height:0;overflow:hidden;transition:max-height .4s ease,opacity .3s ease;opacity:0;}
.qw-c-acc.open{max-height:700px;opacity:1;}
.qw-c-inner{padding:20px 24px 24px;border-top:1px solid var(--qw-line);}
.qw-c-inner-open{padding:20px 24px 24px;}
.qw-c-sum{background:#f5f6fa;border-radius:var(--qw-r-sm);padding:12px 14px;margin-bottom:16px;font-size:12px;color:var(--qw-text-2);line-height:1.5;}
.qw-c-sum strong{color:var(--qw-text);font-weight:600;}

/* Forms */
.qw-f-row{display:grid;grid-template-columns:1fr;gap:14px;margin-bottom:14px;}
@media(min-width:560px){.qw-f-row.two{grid-template-columns:1fr 1fr;}}
.qw-f-grp{display:flex;flex-direction:column;gap:5px;}
.qw-f-lbl{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;color:var(--qw-text-3);}
.qw-req{color:var(--qw-accent);margin-left:2px;}
.qw-f-inp,.qw-f-ta{width:100%;padding:11px 14px;font-size:14px;font-family:inherit;color:var(--qw-text);background:var(--qw-white);border:1px solid var(--qw-line);border-radius:var(--qw-r-sm);transition:all var(--qw-ease);box-sizing:border-box;}
.qw-f-inp:focus,.qw-f-ta:focus{outline:none;border-color:var(--qw-accent);box-shadow:0 0 0 2px rgba(37,99,235,0.1);}
.qw-f-inp::placeholder,.qw-f-ta::placeholder{color:var(--qw-text-3);}
.qw-f-ta{min-height:90px;resize:vertical;line-height:1.5;}
/* [4.2] Inline validation errors */
.qw-f-err{display:block;font-size:12px;color:#dc2626;min-height:16px;margin-top:2px;}
.qw-f-sub{display:flex;align-items:center;justify-content:center;gap:7px;padding:12px 24px;background:var(--qw-dark);color:#fff;border:none;border-radius:var(--qw-r-sm);font-family:inherit;font-size:14px;font-weight:700;cursor:pointer;margin-top:4px;width:100%;}
.qw-f-sub:hover{background:#0a0a0f;}
.qw-f-sub:disabled{opacity:0.5;cursor:not-allowed;}
.qw-f-ok{display:none;text-align:center;padding:28px 20px;}
.qw-f-ok.show{display:block;}
.qw-f-ok h3{font-size:18px;font-weight:700;color:var(--qw-green);margin:0 0 4px;}
.qw-f-ok p{font-size:14px;color:var(--qw-text-2);margin:0;}

/* Restart */
.qw-restart{display:flex;align-items:center;justify-content:center;gap:5px;padding:10px;margin-top:16px;background:none;border:none;font-family:inherit;font-size:13px;font-weight:500;color:var(--qw-text-3);cursor:pointer;width:100%;}
.qw-restart:hover{color:var(--qw-accent);}
/* Urgent */
.qw-urgent{background:#FEF3C7;border-left:4px solid #F59E0B;padding:12px 16px;border-radius:0 var(--qw-r-sm) var(--qw-r-sm) 0;margin-bottom:16px;font-size:14px;font-weight:600;color:#92400E;}
/* Loading */
.qw-loading{text-align:center;padding:48px 16px;}
.qw-loading p{font-size:14px;color:var(--qw-text-2);margin-top:16px;}
.qw-spinner{width:32px;height:32px;border:3px solid var(--qw-line);border-top-color:var(--qw-accent);border-radius:50%;animation:qwSpin 0.7s linear infinite;margin:0 auto;}
@keyframes qwSpin{to{transform:rotate(360deg);}}
/* Empty */
.qw-empty{text-align:center;padding:40px 16px;}
.qw-empty p{font-size:15px;color:var(--qw-text-2);margin-bottom:16px;}

/* [5.1] Sticky CTA */
.qw-sticky-cta{display:none;position:fixed;bottom:0;left:0;right:0;z-index:100;background:var(--qw-white);border-top:1px solid var(--qw-line);padding:12px 16px;box-shadow:0 -4px 20px rgba(0,0,0,0.08);align-items:center;justify-content:space-between;gap:12px;}
.qw-sticky-cta.show{display:flex;}
.qw-sticky-price{font-size:22px;font-weight:700;color:var(--qw-dark);}
.qw-sticky-book{padding:12px 24px;background:var(--qw-accent);color:#fff;border-radius:var(--qw-r-sm);font-family:inherit;font-size:14px;font-weight:700;text-decoration:none;white-space:nowrap;}
@media(min-width:1024px){.qw-sticky-cta{display:none !important;}}

/* Focus visible */
.qw-wizard [tabindex]:focus-visible{outline:2px solid var(--qw-accent);outline-offset:2px;}
</style>

{% schema %}
{
  "name": "Quote Wizard",
  "tag": "section",
  "class": "quote-wizard-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_map",
      "label": "Show map & contact details",
      "default": true
    },
    {
      "type": "html",
      "id": "map_html",
      "label": "Map embed HTML",
      "info": "Paste a Google Maps embed iframe. Leave blank for default iCorrect map."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get your free quote"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Pick your device and we'll point you to the right repair."
    },
    {
      "type": "text",
      "id": "warranty_label",
      "label": "Warranty badge label",
      "default": "2-year warranty"
    },
    {
      "type": "text",
      "id": "diagnostic_turnaround",
      "label": "Diagnostic turnaround label",
      "default": "2 working days"
    }
  ],
  "presets": [{ "name": "Quote Wizard" }]
}
{% endschema %}
