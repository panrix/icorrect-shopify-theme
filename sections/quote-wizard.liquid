  /* =============================================
     CART
     ============================================= */

  function buildCartItems() {
    var err = document.getElementById('qwWalkinErr');
    if (err) err.textContent = '';
    var items = [];

    var resCard = document.getElementById('qwResCard');
    var mainVid = resCard ? parseInt(resCard.dataset.vid, 10) : null;
    if (!mainVid) return null;

    var needsColor = resCard.dataset.needsColor === '1';
    var selectedColor = '';
    if (needsColor) {
      var colorBtn = document.querySelector('#qwColorGrid .qw-color-btn.sel');
      if (!colorBtn) {
        if (err) err.textContent = 'Please select your device colour.';
        return null;
      }
      selectedColor = colorBtn.dataset.color || '';
    }

    var mainProps = {
      '_device': DN[S.device] || S.device,
      '_model': S.model || '',
      '_fault': S.fault || '',
      '_issue': S.issue || ''
    };
    if (selectedColor) mainProps['Device Color'] = selectedColor;
    items.push({ id: mainVid, quantity: 1, properties: mainProps });

    var speedCard = document.querySelector('.qw-opt-card.sel[data-opt="speed"]');
    if (speedCard) {
      var speedVid = parseInt(speedCard.dataset.vid || '0', 10);
      if (speedVid && speedVid > 0) {
        items.push({ id: speedVid, quantity: 1 });
      }
    }

    var svcCard = document.querySelector('.qw-opt-card.sel[data-opt="svc"]');
    var svcAdd = svcCard ? parseInt(svcCard.dataset.add || '0', 10) : 0;
    var isWalkIn = svcAdd === 0;

    if (isWalkIn) {
      var wiVid = CFG.walkIn ? CFG.walkIn.variantId : null;
      if (wiVid && wiVid !== 'null') {
        var walkDate = document.getElementById('qwWalkDate');
        var walkTime = document.getElementById('qwWalkTime');
        if (!walkDate || !walkDate.value) {
          if (err) err.textContent = 'Please select a preferred date.';
          return null;
        }
        if (!walkTime || !walkTime.value) {
          if (err) err.textContent = 'Please select a preferred time.';
          return null;
        }
        items.push({
          id: parseInt(wiVid, 10),
          quantity: 1,
          properties: {
            'Service Type': 'Walk-in',
            'Preferred Date': walkDate.value,
            'Preferred Time': walkTime.value
          }
        });
      }
    } else {
      var miVid = CFG.mailIn ? CFG.mailIn.variantId : null;
      if (miVid && miVid !== 'null') {
        items.push({
          id: parseInt(miVid, 10),
          quantity: 1,
          properties: { 'Service Type': 'Mail-in Service' }
        });
      }
    }

    return items;
  }

  function getShopifyRoot() {
    return (window.Shopify && window.Shopify.routes ? window.Shopify.routes.root : '/');
  }

  async function ensureCleanWizardCart() {
    var root = getShopifyRoot();
    var cartRes = await fetch(root + 'cart.js', { headers: { 'Accept': 'application/json' } });
    if (!cartRes.ok) throw new Error('Could not check the current cart.');

    var cart = await cartRes.json();
    var items = cart && cart.items ? cart.items : [];
    if (!items.length) return true;

    var confirmed = window.confirm('Your cart already has items in it. Continuing with this repair booking will replace them. Do you want to continue?');
    if (!confirmed) {
      trackWizardEvent('wizard_cart_replace_cancelled', {
        cartItemCount: items.length
      });
      return false;
    }

    trackWizardEvent('wizard_cart_replace_confirmed', {
      cartItemCount: items.length
    });

    var clearRes = await fetch(root + 'cart/clear.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      }
    });
    if (!clearRes.ok) throw new Error('Could not prepare a clean checkout. Please try again.');
    return true;
  }

  async function addToCartAndCheckout() {
    var items = buildCartItems();
    if (!items) {
      if (window.posthog) {
        var errEl = document.getElementById('qwWalkinErr');
        posthog.capture('book_now_validation_failed', buildWizardTrackPayload({
          reason: errEl && errEl.textContent ? errEl.textContent : 'unknown'
        }));
      }
      return;
    }

    var btn = document.getElementById('qwBookBtn');
    if (btn) { btn.disabled = true; btn.textContent = 'Redirecting...'; }

    try {
      var shouldContinue = await ensureCleanWizardCart();
      if (!shouldContinue) {
        if (btn) { btn.disabled = false; btn.textContent = 'Proceed to checkout'; }
        return;
      }

      var addRes = await fetch(getShopifyRoot() + 'cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({ items: items })
      });

      if (!addRes.ok) {
        var errData = null;
        try { errData = await addRes.json(); } catch (e) {}
        throw new Error((errData && (errData.description || errData.message)) || 'Cart error');
      }

      await addRes.json();
      trackWizardSubmit('checkout', {
        route: S.route || null,
        value: getWizardTotalValue(),
        currency: 'GBP',
        item_count: items.length
      });
      trackWizardGA4('begin_checkout', {
        route: S.route || null,
        value: getWizardTotalValue(),
        currency: 'GBP',
        item_count: items.length
      });
      var checkoutUrl = '/checkout';
      if (window.posthog && posthog.get_distinct_id) {
        checkoutUrl += '?ph_distinct_id=' + encodeURIComponent(posthog.get_distinct_id());
      }
      window.location.href = checkoutUrl;
    } catch (err) {
      if (btn) { btn.disabled = false; btn.textContent = 'Proceed to checkout'; }
      alert(err.message || 'Something went wrong. Please try again.');
    }
  }

  /* =============================================
     RESOLUTION CARDS
     ============================================= */
  async function showResolution(iss) {
    var p = document.getElementById('qw-rP');
    if (!p) return;
    S.route = iss.route || null;
    S.repairType = iss.repairType || null;
    _resolutionSeen = true;
    _resolutionConverted = false;
    p.style.display = 'block';
    p.innerHTML = '<div class="qw-loading"><div class="qw-spinner"></div></div>';
    updateProg(4);
    if (iss.route === 'repair') await showRepairCard(iss, p);
    else if (iss.route === 'diagnostic') await showDiagnosticCard(iss, p);
