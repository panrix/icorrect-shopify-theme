    panel.innerHTML = '<div class="qw-help-card"><div style="padding:20px;"><p class="qw-help-inst">Go to <code>Settings > General > About</code> on your device. The model number is listed there.</p></div><button class="qw-help-close">Close</button></div>';
    panel.querySelector('.qw-help-close').onclick = function() { panel.classList.remove('open'); };
