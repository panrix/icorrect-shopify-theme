  /* =============================================
     STEP 3: FAULTS
     ============================================= */
  function renderFaults(dev) {
    var c = document.getElementById('qw-fC'); c.innerHTML = '';
    document.getElementById('qw-s3t').textContent = "What's wrong with your " + DN[dev] + "?";

    var faults = getAvailableFaults(dev, _repairsMap);
    if (faults.length === 0) {
      c.innerHTML = '<div class="qw-empty"><p>We\'re setting up pricing for this model. Get in touch for a quote.</p><a href="/pages/contact" class="qw-btn-book">Contact us</a></div>';
      return;
    }

    faults.forEach(function(f) {
      var card = document.createElement('div');
      card.className = 'qw-f-card'; card.tabIndex = 0; card.setAttribute('role', 'button');
      card.innerHTML = '<div class="qw-f-ico">' + (FAULT_ICONS[f.icon] || FAULT_ICONS.other) + '</div><span class="qw-f-lbl">' + esc(f.label) + '</span>';
      card.onclick = function() { pickFault(f.v, card); };
      card.onkeydown = function(e) { if (e.key === 'Enter') pickFault(f.v, card); };
      c.appendChild(card);
    });
  }

  function pickFault(v, el) {
    S.fault = v; S.issue = null;
    document.querySelectorAll('#qw-s3 .qw-f-card').forEach(function(c) { c.classList.remove('sel'); });
    el.classList.add('sel');
    if (window.posthog) posthog.capture('wizard_step', { step: 4, device: S.device, model: S.model, fault: S.fault });
    setTimeout(function() { renderIssues(S.device, v); go(4); }, 150);
  }

  /* =============================================
     STEP 4: ISSUES + RESOLUTION
     ============================================= */
  function renderIssues(dev, fault) {
    var c = document.getElementById('qw-tC'); c.innerHTML = '';
    document.getElementById('qw-rP').style.display = 'none';
    document.getElementById('qw-rP').innerHTML = '';

    var issues = getAvailableIssues(dev, fault, _repairsMap);
    document.getElementById('qw-s4t').textContent = fault;
    document.getElementById('qw-s4s').textContent = 'Which best describes the problem?';

    /* Get the fault icon for this category */
    var faultObj = (FAULTS[dev] || []).find(function(f) { return f.v === fault; });
    var fi = FAULT_ICONS[(faultObj && faultObj.icon) || 'other'] || FAULT_ICONS.other;

    if (issues.length === 0) {
      c.innerHTML = '<div class="qw-empty"><p>No specific issues found. Get in touch and we\'ll help.</p><a href="/pages/contact" class="qw-btn-book">Contact us</a></div>';
      return;
    }

    issues.forEach(function(iss) {
      var card = document.createElement('div');
      card.className = 'qw-t-card'; card.tabIndex = 0; card.setAttribute('role', 'button');
      card.innerHTML = '<div class="qw-tw">' + fi + '</div><span class="qw-tt">' + esc(iss.label) + '</span>';
      card.onclick = function() { pickIssue(iss, card); };
      card.onkeydown = function(e) { if (e.key === 'Enter') pickIssue(iss, card); };
      c.appendChild(card);
    });
  }

  function pickIssue(iss, el) {
    S.issue = iss.label;
    document.querySelectorAll('#qw-s4 .qw-t-card').forEach(function(c) { c.classList.remove('sel'); });
    el.classList.add('sel');
    if (window.posthog) posthog.capture('wizard_step', { step: 'resolution', device: S.device, model: S.model, fault: S.fault });
    showResolution(iss);
  }

  /* =============================================
     RESOLUTION: REPAIR / DIAGNOSTIC / CONTACT
     ============================================= */
  async function showResolution(iss) {
    var p = document.getElementById('qw-rP');
    p.style.display = 'block';
    p.innerHTML = '<div class="qw-loading"><div class="qw-spinner"></div></div>';

    /* Update progress to step 4 (Result) */
    document.querySelectorAll('.qw-prog-s').forEach(function(el) {
      var s = parseInt(el.dataset.s); el.classList.remove('on', 'done');
      if (s < 4) el.classList.add('done'); else if (s === 4) el.classList.add('on');
    });

    if (iss.route === 'repair') await showRepairCard(iss, p);
    else if (iss.route === 'diagnostic') await showDiagnosticCard(iss, p);
    else showContactCard(iss, p);

    if (window.posthog) {
      posthog.capture('wizard_resolution', { route: iss.route, device: S.device, model: S.model, fault: S.fault, issue: S.issue });
    }
    setTimeout(function() { p.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 80);
  }

  /* ---- REPAIR CARD ---- */
