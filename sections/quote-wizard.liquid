  /* ---- WIRING FUNCTIONS ---- */
  function wireOptCards(container) {
    container.querySelectorAll('.qw-opt-card').forEach(function(card) {
      card.onclick = function() {
        var resCard = document.getElementById('qwResCard');
        if (!resCard) return;
        var base = parseInt(resCard.dataset.base, 10);
        var group = card.dataset.opt;
        card.parentNode.querySelectorAll('.qw-opt-card[data-opt="' + group + '"]').forEach(function(c) { c.classList.remove('sel'); });
        card.classList.add('sel');
        var total = base;
        resCard.querySelectorAll('.qw-opt-card.sel').forEach(function(c) { total += parseInt(c.dataset.add || 0, 10); });
        var totalEl = document.getElementById('qwPriceTotal');
        if (totalEl) totalEl.textContent = '\u00A3' + total;
      };
    });
  }

  function wireCFToggle(container) {
    var toggle = container.querySelector('#qwToggleCF');
    if (toggle) {
      toggle.onclick = function() {
        var acc = document.getElementById('qwCAcc');
        acc.classList.toggle('open');
        if (acc.classList.contains('open')) {
          setTimeout(function() { acc.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 180);
          wireContactForm(container, 'qwCF', 'qwFOk', 'qwCFn', 'qwCFe', 'qwCFp', 'qwCFm', 'question');
        }
      };
    }
  }

  function wireContactForm(container, formId, okId, nId, eId, pId, mId, source) {
    var form = document.getElementById(formId);
    if (!form || form._wired) return;
    form._wired = true;

    form.onsubmit = function(e) {
      e.preventDefault();
      var n = document.getElementById(nId).value.trim();
      var em = document.getElementById(eId).value.trim();
      var ph = document.getElementById(pId).value.trim();
      var msg = (document.getElementById(mId).value || '').trim();

      if (!n || n.length < 2 || em.indexOf('@') === -1 || ph.replace(/\D/g, '').length < 8) {
        alert('Please fill in all required fields correctly.');
        return;
      }

      var sub = form.querySelector('.qw-f-sub');
      sub.disabled = true; sub.textContent = 'Sending...';

      fetch('https://icorrect.app.n8n.cloud/workflow/tNQphRiUo0L8SdBn', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          source: 'quote-wizard-' + source,
          device: S.device || '', model: S.model || '', fault: S.fault || '', issue: S.issue || '',
          route: source, name: n, email: em, phone: ph, message: msg,
          url: window.location.href, timestamp: new Date().toISOString()
        })
      }).then(function(res) {
        if (res.ok) {
          document.getElementById(formId).style.display = 'none';
          document.getElementById(okId).classList.add('show');
          if (window.posthog) posthog.capture('wizard_conversion', { action: source + '_submit', device: S.device, model: S.model, fault: S.fault, issue: S.issue });
        } else {
          sub.disabled = false; sub.textContent = 'Send question';
        }
      }).catch(function() { sub.disabled = false; sub.textContent = 'Send question'; });
    };
  }

  function wireRestart(container) {
    var btn = container.querySelector('#qwRestart');
    if (btn) btn.onclick = function() { reset(); };
  }

  function wireBookTracking(container) {
    var btn = container.querySelector('.qw-btn-book');
    if (btn) {
      btn.addEventListener('click', function() {
        if (window.posthog) posthog.capture('wizard_conversion', { action: 'book_repair', device: S.device, model: S.model, fault: S.fault, issue: S.issue });
      });
    }
  }

  function reset() {
    S.device = null; S.model = null; S.fault = null; S.issue = null; S.step = 1; S.collectionHandle = null; _repairsMap = {};
    document.querySelectorAll('.qw-dev').forEach(function(c) { c.classList.remove('sel'); });
    document.getElementById('qw-rP').style.display = 'none';
    document.getElementById('qw-rP').innerHTML = '';
    go(1);
  }

  /* =============================================
     BACK BUTTONS
     ============================================= */
  document.getElementById('qw-back2').onclick = function() { go(1); };
  document.getElementById('qw-back3').onclick = function() { go(2); };
  document.getElementById('qw-back4').onclick = function() { go(3); };

  /* =============================================
     PRE-FILL SYSTEM
     ============================================= */
  function findModelByCollection(handle) {
    var devices = ['macbook', 'iphone', 'ipad', 'watch'];
    for (var d = 0; d < devices.length; d++) {
      var groups = MODELS[devices[d]];
      if (!groups) continue;
      for (var g = 0; g < groups.length; g++) {
        for (var m = 0; m < groups[g].models.length; m++) {
          if (groups[g].models[m].collectionHandle === handle) {
            return { device: devices[d], model: groups[g].models[m] };
          }
        }
      }
    }
    return null;
  }

  function initPrefill() {
    var ctx = CONTEXT;
    if (!ctx) { go(1); return; }

    if (ctx.collectionHandle) {
      var modelMatch = findModelByCollection(ctx.collectionHandle);
      if (modelMatch) {
        S.device = modelMatch.device;
        pickModel(modelMatch.model.name, modelMatch.model.collectionHandle, null);
        return;
      }
    }

    if (ctx.device) {
      S.device = ctx.device;
      if (ctx.fault) S.preFault = ctx.fault;
      renderDevices();
      renderModels(ctx.device);
      go(2);
      return;
    }

    renderDevices();
    go(1);
  }

  /* =============================================
     BROWSER BACK BUTTON
     ============================================= */
  window.addEventListener('popstate', function(e) {
    if (e.state && typeof e.state.step === 'number') {
      S.device = e.state.device || null;
      S.model = e.state.model || null;
      S.fault = e.state.fault || null;
      S.issue = null;
      document.querySelectorAll('.qw-step').forEach(function(el) { el.classList.remove('on'); });
      document.getElementById('qw-s' + e.state.step).classList.add('on');
      updateProg(e.state.step);
    }
  });

  /* =============================================
     INIT
     ============================================= */
  initPrefill();

})();
</script>

