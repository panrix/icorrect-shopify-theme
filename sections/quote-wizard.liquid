  // === UTILITY: HTML ESCAPING (XSS prevention) ===
  function escapeHtml(str) {
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // === REPAIR TYPE RESOLUTION ===
  function deriveRepairTypeFromHandle(handle) {
    var keys = Object.keys(HANDLE_SUFFIX_MAP);
    keys.sort(function(a, b) { return b.length - a.length; });
    for (var i = 0; i < keys.length; i++) {
      if (handle.endsWith(keys[i])) {
        return HANDLE_SUFFIX_MAP[keys[i]];
      }
    }
    return null;
  }

  // === FETCH COLLECTION PRODUCTS ===
  async function fetchCollection(handle) {
    if (_collectionCache[handle]) return _collectionCache[handle];
    try {
      var res = await fetch('/collections/' + handle + '/products.json?limit=250');
      if (!res.ok) return [];
      var data = await res.json();
      _collectionCache[handle] = data.products;
      return data.products;
    } catch(e) {
      return [];
    }
  }

  // === BUILD REPAIRS MAP FROM COLLECTION PRODUCTS ===
  function buildRepairsMap(products) {
    var map = {};
    for (var i = 0; i < products.length; i++) {
      var p = products[i];
      var rt = deriveRepairTypeFromHandle(p.handle);
      if (rt) {
        map[rt] = p;
      }
    }
    return map;
  }

  // === FETCH INDIVIDUAL PRODUCT (for pricing, with 1 retry) ===
  async function fetchProduct(handle) {
    if (_productCache[handle]) return _productCache[handle];
    try {
      var res = await fetch('/products/' + handle + '.json');
      if (!res.ok) throw new Error('not ok');
      var data = await res.json();
      _productCache[handle] = data.product;
      return data.product;
    } catch(e) {
      // 1 retry after 1s delay
      await new Promise(function(r) { setTimeout(r, 1000); });
      try {
        var res2 = await fetch('/products/' + handle + '.json');
        if (!res2.ok) return null;
        var data2 = await res2.json();
        _productCache[handle] = data2.product;
        return data2.product;
      } catch(e2) {
        return null;
      }
    }
  }

  // === FILTER FAULTS BY AVAILABLE PRODUCTS ===
  function getAvailableFaults(device, repairsMap) {
    var available = {};
    for (var repairType in repairsMap) {
      var fault = REPAIR_TYPE_TO_FAULT[repairType];
      if (fault && fault !== '_diagnostic') {
        available[fault] = true;
      }
    }

    // Always show these (they route to diagnostic/contact, not specific products)
    available['Water Damage'] = true;
    available['Data Recovery'] = true;
    available['Other'] = true;

    return FAULTS[device].filter(function(f) {
      return available[f.v];
    });
  }

  // === FILTER ISSUES BY AVAILABLE PRODUCTS ===
  function getAvailableIssues(device, fault, repairsMap) {
    var issues = TS[device] && TS[device][fault];
    if (!issues) return [];

    return issues.filter(function(iss) {
      // Contact routes always show (no product dependency)
      if (iss.route === 'contact') return true;
      // Diagnostic routes show only if diagnostic product exists
      if (iss.route === 'diagnostic') return !!repairsMap['diagnostic'];
      // Repair routes show only if their specific repair product exists
      return !!repairsMap[iss.repairType];
    });
  }

  // === STEP NAVIGATION ===
  function go(n) {
    S.step = n;
    history.pushState(
      { step: n, device: S.device, model: S.model, fault: S.fault },
      ''
    );
    updateProgress(n);
    renderStep(n);
  }

  function updateProgress(step) {
    var bar = document.querySelector('.qw-progress-bar');
    var container = document.querySelector('.qw-progress');
    if (bar) bar.style.width = (step / 4 * 100) + '%';
    if (container) container.setAttribute('aria-valuenow', step);
  }

  function renderStep(n) {
    var content = document.getElementById('qw-content');
    var result = document.getElementById('qw-result');
    if (!content || !result) return;

    result.innerHTML = '';

    switch(n) {
      case 1: renderDevices(content); break;
      case 2: renderModels(content); break;
      case 3: renderFaults(content); break;
      case 4: renderIssues(content); break;
    }
  }

  // === STEP 1: DEVICES ===
  function renderDevices(container) {
    var html = '<div class="qw-grid qw-grid-4">';
    for (var i = 0; i < DEVS.length; i++) {
      var d = DEVS[i];
      html += '<button class="qw-card" data-device="' + d.id + '" tabindex="0">';
      html += '<div class="qw-card-icon">' + d.icon + '</div>';
      html += '<div class="qw-card-label">' + d.label + '</div>';
      html += '</button>';
    }
    html += '</div>';
    container.innerHTML = html;

    var cards = container.querySelectorAll('.qw-card');
    for (var j = 0; j < cards.length; j++) {
      cards[j].addEventListener('click', function() {
        pickDev(this.getAttribute('data-device'));
      });
    }
  }

  function pickDev(deviceId) {
    S.device = deviceId;
    S.model = null;
    S.fault = null;
    S.issue = null;
    S.collectionHandle = null;
    _repairsMap = {};

    if (window.posthog) {
      posthog.capture('wizard_step', { step: 2, device: S.device, model: null, fault: null });
    }

    go(2);
  }

  // === STEP 2: MODELS ===
  function renderModels(container) {
    var groups = MODELS[S.device];
    if (!groups || groups.length === 0) {
      container.innerHTML = '<div class="qw-empty">' +
        '<p>Contact us for a quote on this device.</p>' +
        '<a href="/pages/contact" class="qw-btn">Get in touch</a>' +
        '</div>';
      return;
    }

    var html = '<div class="qw-back-row"><button class="qw-back" tabindex="0">&larr; Back</button></div>';
    html += '<div class="qw-model-list">';
    for (var g = 0; g < groups.length; g++) {
      html += '<div class="qw-model-group">';
      html += '<h3 class="qw-model-group-label">' + escapeHtml(groups[g].group) + '</h3>';
      for (var m = 0; m < groups[g].models.length; m++) {
        var model = groups[g].models[m];
        html += '<button class="qw-model-btn" data-handle="' + model.collectionHandle + '" data-name="' + escapeHtml(model.name) + '" tabindex="0">';
        html += escapeHtml(model.name);
        html += '</button>';
      }
      html += '</div>';
    }
    html += '</div>';
    container.innerHTML = html;

    // Back button
    container.querySelector('.qw-back').addEventListener('click', function() { go(1); });

    // Model buttons
    var btns = container.querySelectorAll('.qw-model-btn');
    for (var b = 0; b < btns.length; b++) {
      btns[b].addEventListener('click', function() {
        pickModel(this.getAttribute('data-name'), this.getAttribute('data-handle'));
      });
    }
  }

  async function pickModel(name, handle) {
    S.model = name;
    S.collectionHandle = handle;
    S.fault = null;
    S.issue = null;

    // Show loading state
    var content = document.getElementById('qw-content');
    if (content) {
      content.innerHTML = '<div class="qw-loading"><div class="qw-spinner"></div><p>Loading repairs for ' + escapeHtml(name) + '...</p></div>';
    }

    // Fetch collection products and build repairs map
    var products = await fetchCollection(handle);
    _repairsMap = buildRepairsMap(products);

    if (window.posthog) {
      posthog.capture('wizard_step', { step: 3, device: S.device, model: S.model, fault: null });
    }

    // Check for pre-queued fault from pre-fill
    if (S.preFault) {
      var pf = S.preFault;
      S.preFault = null;
      S.fault = pf;
      go(4);
      return;
    }

    go(3);
  }

  // === STEP 3: FAULTS ===
  function renderFaults(container) {
    var faults = getAvailableFaults(S.device, _repairsMap);

    if (faults.length === 0) {
      container.innerHTML = '<div class="qw-empty">' +
        '<p>We\'re setting up pricing for this model. Get in touch for a quote.</p>' +
        '<a href="/pages/contact" class="qw-btn">Contact us</a>' +
        '</div>';
      return;
    }

    var html = '<div class="qw-back-row"><button class="qw-back" tabindex="0">&larr; Back</button></div>';
    html += '<h3 class="qw-step-label">What\'s the issue with your ' + escapeHtml(S.model) + '?</h3>';
    html += '<div class="qw-grid qw-grid-3">';
    for (var i = 0; i < faults.length; i++) {
      var f = faults[i];
      var iconHtml = FAULT_ICONS[f.icon] || '';
      html += '<button class="qw-card qw-fault-card" data-fault="' + escapeHtml(f.v) + '" tabindex="0">';
      html += '<div class="qw-card-icon">' + iconHtml + '</div>';
      html += '<div class="qw-card-label">' + escapeHtml(f.label) + '</div>';
      html += '</button>';
    }
    html += '</div>';
    container.innerHTML = html;

    container.querySelector('.qw-back').addEventListener('click', function() { go(2); });

    var cards = container.querySelectorAll('.qw-fault-card');
    for (var c = 0; c < cards.length; c++) {
      cards[c].addEventListener('click', function() {
        pickFault(this.getAttribute('data-fault'));
      });
    }
  }

  function pickFault(faultValue) {
    S.fault = faultValue;
    S.issue = null;

    if (window.posthog) {
      posthog.capture('wizard_step', { step: 4, device: S.device, model: S.model, fault: S.fault });
    }

    go(4);
  }

  // === STEP 4: ISSUES ===
  function renderIssues(container) {
    var issues = getAvailableIssues(S.device, S.fault, _repairsMap);

    if (issues.length === 0) {
      container.innerHTML = '<div class="qw-empty">' +
        '<p>No specific issues found. Get in touch and we\'ll help.</p>' +
        '<a href="/pages/contact" class="qw-btn">Contact us</a>' +
        '</div>';
      return;
    }

    var html = '<div class="qw-back-row"><button class="qw-back" tabindex="0">&larr; Back</button></div>';
    html += '<h3 class="qw-step-label">Which best describes your issue?</h3>';
    html += '<div class="qw-issue-list">';
    for (var i = 0; i < issues.length; i++) {
      var iss = issues[i];
      html += '<button class="qw-issue-btn" data-index="' + i + '" tabindex="0">';
      html += escapeHtml(iss.label);
      html += '</button>';
    }
    html += '</div>';
    container.innerHTML = html;

    container.querySelector('.qw-back').addEventListener('click', function() { go(3); });

    var filteredIssues = issues;
    var btns = container.querySelectorAll('.qw-issue-btn');
    for (var b = 0; b < btns.length; b++) {
      btns[b].addEventListener('click', function() {
        var idx = parseInt(this.getAttribute('data-index'), 10);
        pickIssue(filteredIssues[idx]);
      });
    }
  }

  function pickIssue(iss) {
    S.issue = iss.label;

    if (window.posthog) {
      posthog.capture('wizard_step', { step: 'resolution', device: S.device, model: S.model, fault: S.fault });
    }

    showResolution(iss);
  }

  // === RESOLUTION DISPATCHER ===
  async function showResolution(iss) {
    var result = document.getElementById('qw-result');
    if (!result) return;

    var content = document.getElementById('qw-content');
    if (content) content.innerHTML = '<div class="qw-back-row"><button class="qw-back" tabindex="0">&larr; Start over</button></div>';

    var backBtn = content && content.querySelector('.qw-back');
    if (backBtn) backBtn.addEventListener('click', function() { go(1); });

    switch(iss.route) {
      case 'repair':
        await showRepairCard(iss, result);
        break;
      case 'diagnostic':
        await showDiagnosticCard(iss, result);
        break;
      case 'contact':
        showContactCard(iss, result);
        break;
    }

    if (window.posthog) {
      posthog.capture('wizard_resolution', {
        route: iss.route,
        device: S.device,
        model: S.model,
        fault: S.fault,
        issue: S.issue
      });
    }

    var heading = result.querySelector('h3, h4');
    if (heading) heading.focus();
  }

  // === TEMPLATE A: REPAIR CARD ===
  async function showRepairCard(iss, container) {
    var product = _repairsMap[iss.repairType];
    if (!product) {
      showContactCard(iss, container);
      return;
    }

    var html = '';

    if (iss.urgent) {
      html += '<div class="qw-urgent" role="alert">';
      html += '<span>\u26A0\uFE0F Safety concern: stop using the device and don\'t charge it.</span>';
      html += '</div>';
    }

    html += '<div class="qw-resolution qw-resolution-repair">';
    html += '<div class="qw-badge qw-badge-green"><span class="qw-badge-icon">\u2713</span> We can fix this</div>';
    html += '<h3 tabindex="-1">' + escapeHtml(product.title) + '</h3>';
    html += '<p class="qw-copy">' + escapeHtml(iss.copy) + '</p>';
    html += '<div class="qw-price" id="qw-price"><div class="qw-skeleton-price"></div></div>';
    html += '<div class="qw-ctas">';
    html += '<a href="/products/' + product.handle + '" class="qw-btn qw-btn-primary">Book this repair</a>';
    html += '<button class="qw-btn qw-btn-secondary qw-question-toggle" tabindex="0">I have a question</button>';
    html += '</div>';
    html += '</div>';
    container.innerHTML = html;

    wireQuestionToggle(container);

    var bookBtn = container.querySelector('.qw-btn-primary');
    if (bookBtn) {
      bookBtn.addEventListener('click', function() {
        if (window.posthog) {
          posthog.capture('wizard_conversion', {
            action: 'book_repair', device: S.device, model: S.model, fault: S.fault, issue: S.issue
          });
        }
      });
    }

    // Fetch full product for pricing
    var fullProduct = await fetchProduct(product.handle);
    var priceEl = document.getElementById('qw-price');
    if (fullProduct && priceEl) {
      var price = fullProduct.variants && fullProduct.variants[0] ? fullProduct.variants[0].price : null;
      if (price) {
        priceEl.innerHTML = '<span class="qw-price-value">From \u00A3' + price + '</span>';
      } else {
        priceEl.innerHTML = '<a href="/products/' + product.handle + '" class="qw-price-link">View pricing \u2192</a>';
      }
    } else if (priceEl) {
      priceEl.innerHTML = '<a href="/products/' + product.handle + '" class="qw-price-link">View pricing \u2192</a>';
    }
  }

  // === TEMPLATE B: DIAGNOSTIC CARD ===
  async function showDiagnosticCard(iss, container) {
    var diagProduct = _repairsMap['diagnostic'];
    if (!diagProduct) {
      showContactCard(iss, container);
      return;
    }

    var html = '';

    if (iss.urgent) {
      html += '<div class="qw-urgent" role="alert">';
      html += '<span>\u26A0\uFE0F Safety concern: stop using the device and don\'t charge it.</span>';
      html += '</div>';
    }

    html += '<div class="qw-resolution qw-resolution-diagnostic">';
    html += '<div class="qw-badge qw-badge-amber"><span class="qw-badge-icon">\uD83D\uDD0D</span> We need to take a look</div>';
    html += '<h3 tabindex="-1">Book a Diagnostic</h3>';
    html += '<p class="qw-copy">' + escapeHtml(iss.copy) + '</p>';
    html += '<div class="qw-price" id="qw-price"><div class="qw-skeleton-price"></div></div>';

    if (iss.likelyRepair && _repairsMap[iss.likelyRepair]) {
      html += '<div class="qw-likely-repair" id="qw-likely-price"><div class="qw-skeleton-price"></div></div>';
    }

    html += '<div class="qw-ctas">';
    html += '<a href="/products/' + diagProduct.handle + '" class="qw-btn qw-btn-primary">Book a Diagnostic</a>';
    html += '<button class="qw-btn qw-btn-secondary qw-question-toggle" tabindex="0">I have a question</button>';
    html += '</div>';
    html += '</div>';
    container.innerHTML = html;

    wireQuestionToggle(container);

    var bookBtn = container.querySelector('.qw-btn-primary');
    if (bookBtn) {
      bookBtn.addEventListener('click', function() {
        if (window.posthog) {
          posthog.capture('wizard_conversion', {
            action: 'book_diagnostic', device: S.device, model: S.model, fault: S.fault, issue: S.issue
          });
        }
      });
    }

    // Fetch diagnostic product price
    var fullDiag = await fetchProduct(diagProduct.handle);
    var priceEl = document.getElementById('qw-price');
    if (fullDiag && priceEl) {
      var price = fullDiag.variants && fullDiag.variants[0] ? fullDiag.variants[0].price : null;
      if (price) {
        priceEl.innerHTML = '<span class="qw-price-value">From \u00A3' + price + '</span>';
      } else {
        priceEl.innerHTML = '<a href="/products/' + diagProduct.handle + '" class="qw-price-link">View pricing \u2192</a>';
      }
    } else if (priceEl) {
      priceEl.innerHTML = '<a href="/products/' + diagProduct.handle + '" class="qw-price-link">View pricing \u2192</a>';
    }

    // Fetch likely repair price (SEPARATE try/catch)
    if (iss.likelyRepair && _repairsMap[iss.likelyRepair]) {
      var likelyProduct = _repairsMap[iss.likelyRepair];
      var likelyEl = document.getElementById('qw-likely-price');
      try {
        var fullLikely = await fetchProduct(likelyProduct.handle);
        if (fullLikely && likelyEl) {
          var lp = fullLikely.variants && fullLikely.variants[0] ? fullLikely.variants[0].price : null;
          if (lp && iss.likelyCopy) {
            likelyEl.innerHTML = '<p class="qw-likely-text">' + escapeHtml(iss.likelyCopy) + ': from \u00A3' + lp + '</p>';
          } else {
            likelyEl.innerHTML = '';
          }
        } else if (likelyEl) {
          likelyEl.innerHTML = '';
        }
      } catch(e) {
        if (likelyEl) likelyEl.innerHTML = '';
      }
    }
  }

  // === TEMPLATE C: CONTACT CARD ===
  function showContactCard(iss, container) {
    var html = '';

    if (iss.urgent) {
      html += '<div class="qw-urgent" role="alert">';
      html += '<span>\u26A0\uFE0F Safety concern: stop using the device and don\'t charge it.</span>';
      html += '</div>';
    }

    html += '<div class="qw-resolution qw-resolution-contact">';
    html += '<div class="qw-badge qw-badge-blue"><span class="qw-badge-icon">\uD83D\uDCAC</span> Let\'s chat about this</div>';
    html += '<h3 tabindex="-1">Get in Touch</h3>';
    html += '<p class="qw-copy">' + escapeHtml(iss.copy) + '</p>';
    html += '<form class="qw-contact-form" id="qw-contact-form" novalidate>';
    html += '<div class="qw-field"><label for="qw-name">Name</label><input type="text" id="qw-name" name="name" required minlength="2" autocomplete="name"><span class="qw-error" id="qw-name-err"></span></div>';
    html += '<div class="qw-field"><label for="qw-email">Email</label><input type="email" id="qw-email" name="email" required autocomplete="email"><span class="qw-error" id="qw-email-err"></span></div>';
    html += '<div class="qw-field"><label for="qw-phone">Phone</label><input type="tel" id="qw-phone" name="phone" required autocomplete="tel"><span class="qw-error" id="qw-phone-err"></span></div>';
    html += '<div class="qw-field"><label for="qw-message">Message (optional)</label><textarea id="qw-message" name="message" rows="3"></textarea></div>';
    html += '<button type="submit" class="qw-btn qw-btn-primary qw-submit-btn" disabled>Send</button>';
    html += '</form>';
    html += '</div>';
    container.innerHTML = html;

    wireContactForm();
  }

  // === SHARED FORM VALIDATION ===
  function validateFormFields(nameEl, emailEl, phoneEl, nameErrEl, emailErrEl, phoneErrEl, submitBtn) {
    var valid = true;

    // Name: required, min 2 chars
    if (!nameEl.value || nameEl.value.trim().length < 2) {
      nameErrEl.textContent = 'Please enter your name';
      valid = false;
    } else {
      nameErrEl.textContent = '';
    }

    // Email: required, must contain @ and .
    var ev = emailEl.value.trim();
    if (!ev || ev.indexOf('@') === -1 || ev.indexOf('.') === -1) {
      emailErrEl.textContent = 'Please enter a valid email';
      valid = false;
    } else {
      emailErrEl.textContent = '';
    }

    // Phone: required, min 8 digits
    var digits = (phoneEl.value || '').replace(/\D/g, '');
    if (digits.length < 8) {
      phoneErrEl.textContent = 'Please enter a valid phone number';
      valid = false;
    } else {
      phoneErrEl.textContent = '';
    }

    submitBtn.disabled = !valid;
    return valid;
  }

  // === CONTACT FORM WIRING ===
  function wireContactForm() {
    var form = document.getElementById('qw-contact-form');
    if (!form) return;

    var nameIn = document.getElementById('qw-name');
    var emailIn = document.getElementById('qw-email');
    var phoneIn = document.getElementById('qw-phone');
    var submitBtn = form.querySelector('.qw-submit-btn');

    function validate() {
      return validateFormFields(
        nameIn, emailIn, phoneIn,
        document.getElementById('qw-name-err'),
        document.getElementById('qw-email-err'),
        document.getElementById('qw-phone-err'),
        submitBtn
      );
    }

    nameIn.addEventListener('input', validate);
    emailIn.addEventListener('input', validate);
    phoneIn.addEventListener('input', validate);

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      if (!validate()) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      var payload = {
        source: 'quote-wizard',
        device: S.device || '',
        model: S.model || '',
        fault: S.fault || '',
        issue: S.issue || '',
        route: 'contact',
        name: nameIn.value.trim(),
        email: emailIn.value.trim(),
        phone: phoneIn.value.trim(),
        message: (document.getElementById('qw-message').value || '').trim(),
        url: window.location.href,
        timestamp: new Date().toISOString()
      };

      fetch('https://icorrect.app.n8n.cloud/workflow/tNQphRiUo0L8SdBn', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
      .then(function(res) {
        if (res.ok) {
          form.innerHTML = '<div class="qw-success"><p>Thanks! We\'ll be in touch shortly.</p></div>';
          if (window.posthog) {
            posthog.capture('wizard_conversion', {
              action: 'contact_submit', device: S.device, model: S.model, fault: S.fault, issue: S.issue
            });
          }
        } else {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send';
          var errDiv = form.querySelector('.qw-form-error') || document.createElement('div');
          errDiv.className = 'qw-form-error';
          errDiv.textContent = 'Something went wrong. Please try again.';
          if (!form.querySelector('.qw-form-error')) form.appendChild(errDiv);
        }
      })
      .catch(function() {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send';
        var errDiv = form.querySelector('.qw-form-error') || document.createElement('div');
        errDiv.className = 'qw-form-error';
        errDiv.textContent = 'Something went wrong. Please try again.';
        if (!form.querySelector('.qw-form-error')) form.appendChild(errDiv);
      });
    });
  }

  // === QUESTION TOGGLE (for repair/diagnostic cards) ===
  function wireQuestionToggle(container) {
    var toggle = container.querySelector('.qw-question-toggle');
    if (!toggle) return;

    toggle.addEventListener('click', function() {
      var existing = container.querySelector('.qw-question-form');
      if (existing) {
        existing.remove();
        return;
      }

      var formHtml = '<div class="qw-question-form">';
      formHtml += '<form class="qw-contact-form" id="qw-question-form" novalidate>';
      formHtml += '<div class="qw-field"><label for="qwq-name">Name</label><input type="text" id="qwq-name" name="name" required minlength="2" autocomplete="name"><span class="qw-error" id="qwq-name-err"></span></div>';
      formHtml += '<div class="qw-field"><label for="qwq-email">Email</label><input type="email" id="qwq-email" name="email" required autocomplete="email"><span class="qw-error" id="qwq-email-err"></span></div>';
      formHtml += '<div class="qw-field"><label for="qwq-phone">Phone</label><input type="tel" id="qwq-phone" name="phone" required autocomplete="tel"><span class="qw-error" id="qwq-phone-err"></span></div>';
      formHtml += '<div class="qw-field"><label for="qwq-message">Your question</label><textarea id="qwq-message" name="message" rows="3"></textarea></div>';
      formHtml += '<button type="submit" class="qw-btn qw-btn-primary qw-submit-btn" disabled>Send</button>';
      formHtml += '</form>';
      formHtml += '</div>';

      toggle.insertAdjacentHTML('afterend', formHtml);
      wireQuestionForm();

      if (window.posthog) {
        posthog.capture('wizard_conversion', {
          action: 'question_form', device: S.device, model: S.model, fault: S.fault, issue: S.issue
        });
      }
    });
  }

  function wireQuestionForm() {
    var form = document.getElementById('qw-question-form');
    if (!form) return;

    var nameIn = document.getElementById('qwq-name');
    var emailIn = document.getElementById('qwq-email');
    var phoneIn = document.getElementById('qwq-phone');
    var submitBtn = form.querySelector('.qw-submit-btn');

    function validate() {
      return validateFormFields(
        nameIn, emailIn, phoneIn,
        document.getElementById('qwq-name-err'),
