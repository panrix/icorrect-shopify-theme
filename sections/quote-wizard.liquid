  .qw-wrap { flex-direction: row; align-items: flex-start; gap: 52px; }
  .qw-info { width: 44%; flex-shrink: 0; position: sticky; top: 28px; }
  .qw-wrap .quote-wizard { width: 56%; }
}

/* LEFT: MAP + DETAILS */
.qw-info {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.qw-map {
  width: 100%;
  height: 240px;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid #e4e6ec;
  box-shadow: 0 1px 2px rgba(15,15,20,0.04);
}
@media (min-width: 1024px) {
  .qw-map { height: auto; aspect-ratio: 4 / 3; }
}
.qw-map iframe { width: 100%; height: 100%; border: 0; display: block; }
.qw-details-card {
  background: #ffffff;
  border: 1px solid #e4e6ec;
  border-radius: 16px;
  overflow: hidden;
}
.qw-details-grid {
  display: grid;
  grid-template-columns: 1fr;
}
@media (min-width: 560px) {
  .qw-details-grid { grid-template-columns: 1fr 1fr; }
  .qw-details-left { border-right: 1px solid #e4e6ec; border-bottom: none; }
}
.qw-details-left { border-bottom: 1px solid #e4e6ec; }
.qw-details-col {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}
.qw-d-group {
  display: flex;
  flex-direction: column;
  gap: 5px;
}
.qw-d-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: #8c8c9e;
  display: flex;
  align-items: center;
  gap: 5px;
  margin: 0;
}
.qw-d-label svg { width: 14px; height: 14px; color: #2563eb; flex-shrink: 0; }
.qw-d-val {
  font-size: 14px;
  font-weight: 500;
  line-height: 1.5;
  color: #1d1d2b;
  text-decoration: none;
  display: block;
}
a.qw-d-val:hover { color: #2563eb; }
.qw-hrs {
  display: grid;
  grid-template-columns: 80px 1fr;
  gap: 4px 10px;
  font-size: 13px;
}
.qw-hrs-d { color: #8c8c9e; font-weight: 500; }
.qw-hrs-t { color: #1d1d2b; font-weight: 600; }
.qw-hrs-c { color: #2563eb; }

/* ========================================
   QUOTE WIZARD — SCOPED STYLES
   ======================================== */
.quote-wizard {
  --qw-dark: #0f0f14;
  --qw-text: #1d1d2b;
  --qw-text-2: #4a4a5c;
  --qw-text-3: #8c8c9e;
  --qw-accent: #2563eb;
  --qw-accent-h: #1d4ed8;
  --qw-accent-bg: #eff4ff;
  --qw-bg: #f6f7f9;
  --qw-white: #ffffff;
  --qw-line: #e4e6ec;
  --qw-line-h: #cdd0da;
  --qw-green: #059669;
  --qw-green-bg: #ecfdf5;
  --qw-amber: #D97706;
  --qw-amber-bg: #fffbeb;
  --qw-blue: #2563eb;
  --qw-blue-bg: #eff4ff;
  --qw-r-sm: 8px;
  --qw-r-md: 12px;
  --qw-r-lg: 16px;
  --qw-sh-1: 0 1px 2px rgba(15,15,20,0.04);
  --qw-sh-2: 0 4px 12px rgba(15,15,20,0.07);
  --qw-sh-focus: 0 0 0 3px rgba(37,99,235,0.12);
  --qw-ease: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: var(--qw-text);
  display: flex;
  flex-direction: column;
}

/* Header */
.quote-wizard .qw-header {
  margin-bottom: 24px;
}
.quote-wizard .qw-header h2 {
  font-size: clamp(24px, 4vw, 40px);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.03em;
  color: var(--qw-dark);
  margin: 0 0 6px;
}
.quote-wizard .qw-header p {
  font-size: clamp(14px, 1.1vw, 16px);
  font-weight: 400;
  line-height: 1.5;
  color: var(--qw-text-2);
  margin: 0;
}

/* Progress bar */
.quote-wizard .qw-progress {
  height: 4px;
  background: var(--qw-line);
  border-radius: 2px;
  margin-bottom: 28px;
  overflow: hidden;
}
.quote-wizard .qw-progress-bar {
  height: 100%;
  width: 25%;
  background: var(--qw-accent);
  border-radius: 2px;
  transition: width 0.4s ease;
}

/* Animation */
@keyframes qw-fadeUp {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Content area */
#qw-content, #qw-result {
  animation: qw-fadeUp 0.28s ease-out;
}

/* Grid layouts */
.quote-wizard .qw-grid {
  display: grid;
  gap: 12px;
}
.quote-wizard .qw-grid-4 {
  grid-template-columns: repeat(2, 1fr);
}
.quote-wizard .qw-grid-3 {
  grid-template-columns: repeat(2, 1fr);
}
@media (min-width: 480px) {
  .quote-wizard .qw-grid-4 { grid-template-columns: repeat(4, 1fr); }
  .quote-wizard .qw-grid-3 { grid-template-columns: repeat(3, 1fr); }
}

/* Cards (device + fault) */
.quote-wizard .qw-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 20px 10px;
  background: var(--qw-white);
  border: 2px solid var(--qw-line);
  border-radius: var(--qw-r-md);
  cursor: pointer;
  transition: all var(--qw-ease);
  min-height: 90px;
  text-align: center;
  -webkit-tap-highlight-color: transparent;
  font-family: inherit;
  font-size: inherit;
  color: inherit;
}
.quote-wizard .qw-card:hover {
  border-color: var(--qw-line-h);
  box-shadow: var(--qw-sh-2);
  transform: translateY(-2px);
}
.quote-wizard .qw-card:active {
  transform: scale(0.97);
}
.quote-wizard .qw-card:focus-visible {
  outline: 2px solid var(--qw-accent);
  outline-offset: 2px;
}
.quote-wizard .qw-card-icon {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--qw-text-2);
}
.quote-wizard .qw-card-icon svg {
  width: 100%;
  height: 100%;
}
.quote-wizard .qw-card-label {
  font-size: 13px;
  font-weight: 600;
  line-height: 1.3;
}

/* Back button */
.quote-wizard .qw-back-row {
  margin-bottom: 14px;
}
.quote-wizard .qw-back {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  background: none;
  border: none;
  font-family: inherit;
  font-size: 13px;
  font-weight: 600;
  color: var(--qw-text-3);
  cursor: pointer;
  padding: 6px 0;
  transition: color var(--qw-ease);
}
.quote-wizard .qw-back:hover {
  color: var(--qw-text);
}

/* Step label */
.quote-wizard .qw-step-label {
  font-size: clamp(18px, 2.2vw, 24px);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin: 0 0 16px;
  color: var(--qw-dark);
}

/* Model list */
.quote-wizard .qw-model-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.quote-wizard .qw-model-group {
  border: 1px solid var(--qw-line);
  border-radius: var(--qw-r-md);
  overflow: hidden;
  background: var(--qw-white);
}
.quote-wizard .qw-model-group-label {
  padding: 12px 16px;
  font-size: 14px;
  font-weight: 700;
  color: var(--qw-text);
  margin: 0;
  border-bottom: 1px solid var(--qw-line);
  background: #fafbfc;
}
.quote-wizard .qw-model-btn {
  display: block;
