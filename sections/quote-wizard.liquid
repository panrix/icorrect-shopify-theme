    c.innerHTML = '';
    var titleEl = document.getElementById('qw-s3t');
    if (titleEl) titleEl.textContent = "What's wrong with your " + DN[dev] + "?";

    var faults = getAvailableFaults(dev, _repairsMap);
    if (faults.length === 0) {
      c.innerHTML = '<div class="qw-empty"><p>We\'re setting up pricing for this model. Get in touch for a quote.</p><a href="/pages/contact" class="qw-btn-book">Get in touch</a></div>';
      return;
    }
    faults.forEach(function(f) {
      var card = document.createElement('div');
      card.className = 'qw-f-card';
      card.innerHTML = '<div class="qw-f-ico">' + (FAULT_ICONS[f.icon] || FAULT_ICONS.other) + '</div><span class="qw-f-lbl">' + esc(f.label) + '</span>';
      wireA11y(card, f.label);
      card.onclick = function() { pickFault(f.v, card); };
      c.appendChild(card);
    });
