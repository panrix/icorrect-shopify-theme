  text-align: left;
  padding: 14px 18px;
  background: var(--qw-white);
  border: 2px solid var(--qw-line);
  border-radius: var(--qw-r-md);
  font-family: inherit;
  font-size: 14px;
  font-weight: 600;
  color: var(--qw-text);
  cursor: pointer;
  transition: all var(--qw-ease);
  -webkit-tap-highlight-color: transparent;
}
.quote-wizard .qw-issue-btn:hover {
  border-color: var(--qw-line-h);
  box-shadow: var(--qw-sh-1);
}
.quote-wizard .qw-issue-btn:active {
  transform: scale(0.98);
}
.quote-wizard .qw-issue-btn:focus-visible {
  outline: 2px solid var(--qw-accent);
  outline-offset: 2px;
}

/* Loading state */
.quote-wizard .qw-loading {
  text-align: center;
  padding: 48px 16px;
}
.quote-wizard .qw-loading p {
  font-size: 14px;
  color: var(--qw-text-2);
  margin-top: 16px;
}

/* Spinner */
.quote-wizard .qw-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid var(--qw-line);
  border-top-color: var(--qw-accent);
  border-radius: 50%;
  animation: qw-spin 0.7s linear infinite;
  margin: 0 auto;
}
@keyframes qw-spin {
  to { transform: rotate(360deg); }
}

/* Skeleton loading */
.quote-wizard .qw-skeleton-price {
  width: 120px;
  height: 32px;
  border-radius: 6px;
  background: linear-gradient(90deg, #f0f1f5 25%, #e8e9ee 50%, #f0f1f5 75%);
  background-size: 200% 100%;
  animation: qw-shimmer 1.5s infinite;
}
@keyframes qw-shimmer {
  from { background-position: 200% 0; }
  to { background-position: -200% 0; }
}

/* Empty state */
.quote-wizard .qw-empty {
  text-align: center;
  padding: 40px 16px;
}
.quote-wizard .qw-empty p {
  font-size: 15px;
  color: var(--qw-text-2);
  margin-bottom: 16px;
}

/* Urgent banner */
