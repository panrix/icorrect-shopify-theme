  background: #FEF3C7;
  border-left: 4px solid #F59E0B;
  padding: 12px 16px;
  border-radius: 0 var(--qw-r-sm) var(--qw-r-sm) 0;
  margin-bottom: 16px;
  font-size: 14px;
  font-weight: 600;
  color: #92400E;
}

/* Resolution cards */
.quote-wizard .qw-resolution {
  background: var(--qw-white);
  border: 1px solid var(--qw-line);
  border-radius: var(--qw-r-lg);
  padding: 24px;
  margin-top: 8px;
}

/* Badges */
.quote-wizard .qw-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 5px 12px;
  border-radius: 100px;
  margin-bottom: 14px;
}
.quote-wizard .qw-badge-green {
  background: var(--qw-green-bg);
  color: var(--qw-green);
}
.quote-wizard .qw-badge-amber {
  background: var(--qw-amber-bg);
  color: var(--qw-amber);
}
.quote-wizard .qw-badge-blue {
  background: var(--qw-blue-bg);
  color: var(--qw-blue);
}

.quote-wizard .qw-resolution h3 {
  font-size: 20px;
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.2;
  margin: 0 0 8px;
  color: var(--qw-dark);
}
.quote-wizard .qw-resolution h3:focus {
  outline: none;
}
.quote-wizard .qw-copy {
  font-size: 14px;
