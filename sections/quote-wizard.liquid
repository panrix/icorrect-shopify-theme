        d.onclick = function() {
          /* Find model in MODELS by matching name */
          var groups = MODELS['macbook'] || [];
          for (var g = 0; g < groups.length; g++) {
            for (var m = 0; m < groups[g].models.length; m++) {
              if (groups[g].models[m].name === n.m || n.m.indexOf(groups[g].models[m].name) !== -1) {
                panel.classList.remove('open');
