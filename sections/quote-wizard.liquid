  function wireWalkinPicker(container) {
    var dateInput = document.getElementById('qwWalkDate');
    var timeSelect = document.getElementById('qwWalkTime');
    var panel = document.getElementById('qwWalkinPanel');
    if (!dateInput || !timeSelect || !panel) return;

    var _bookingFormStarted = false;
    function emitBookingFormStarted(field) {
      if (_bookingFormStarted) return;
      _bookingFormStarted = true;
      if (window.posthog) {
        posthog.capture('booking_form_started', buildWizardTrackPayload({ first_field: field }));
      }
    }
    dateInput.addEventListener('focus', function() { emitBookingFormStarted('date'); }, { once: true });
    timeSelect.addEventListener('focus', function() { emitBookingFormStarted('time'); }, { once: true });

    var today = new Date();
    var londonNow = new Date(today.toLocaleString('en-GB', { timeZone: 'Europe/London' }));
    var y = londonNow.getFullYear(), m = String(londonNow.getMonth() + 1).padStart(2, '0'), d = String(londonNow.getDate()).padStart(2, '0');
    dateInput.min = y + '-' + m + '-' + d;
    var maxDate = new Date(londonNow);
    maxDate.setDate(maxDate.getDate() + 60);
    var my = maxDate.getFullYear(), mm = String(maxDate.getMonth() + 1).padStart(2, '0'), md = String(maxDate.getDate()).padStart(2, '0');
    dateInput.max = my + '-' + mm + '-' + md;
    var oneOffBlackoutDates = {
      '2026-05-04': 'We are closed on Monday 4 May 2026 for the UK bank holiday. Please choose another weekday.'
    };

    function formatDateValue(date) {
      return date.getFullYear() + '-' + String(date.getMonth() + 1).padStart(2, '0') + '-' + String(date.getDate()).padStart(2, '0');
    }

    function getOneOffBlackoutMessage(dateValue) {
      return oneOffBlackoutDates[dateValue] || '';
    }

    dateInput.onchange = function() {
      var err = document.getElementById('qwWalkinErr');
      if (err) err.textContent = '';
      timeSelect.innerHTML = '<option value="">Select a time</option>';
      if (!dateInput.value) return;

      var parts = dateInput.value.split('-');
      var selDate = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
      var dow = selDate.getDay();

      if (dow === 0 || dow === 6) {
        if (err) err.textContent = 'We are closed on weekends. Please select a weekday.';
        dateInput.value = '';
        return;
      }

      var holidayMonth = selDate.getMonth() + 1;
      var holidayDay = selDate.getDate();
      if ((holidayMonth === 12 && holidayDay >= 24) || (holidayMonth === 1 && holidayDay <= 4)) {
        if (err) err.textContent = 'We are closed during the holiday period (24 Dec - 4 Jan).';
        dateInput.value = '';
        return;
      }

      var oneOffBlackoutMessage = getOneOffBlackoutMessage(dateInput.value);
      if (oneOffBlackoutMessage) {
        if (err) err.textContent = oneOffBlackoutMessage;
        dateInput.value = '';
        return;
      }

      var startMin = (dow === 5) ? 600 : 570;
      var endMin = 1050;
      var isToday = dateInput.value === (y + '-' + m + '-' + d);

      if (isToday) {
        var nowMin = londonNow.getHours() * 60 + londonNow.getMinutes();
        var ceil = Math.ceil(nowMin / 30) * 30 + 30;
        if (ceil > startMin) startMin = ceil;
      }

      if (startMin >= endMin) {
        if (err) err.textContent = 'No more slots available today. Please pick another day.';
        dateInput.value = '';
        return;
      }

      for (var t = startMin; t <= endMin; t += 30) {
        var h = Math.floor(t / 60);
        var mi = t % 60;
        var ampm = h >= 12 ? 'PM' : 'AM';
        var h12 = h > 12 ? h - 12 : (h === 0 ? 12 : h);
        var label = h12 + ':' + String(mi).padStart(2, '0') + ' ' + ampm;
        var opt = document.createElement('option');
        opt.value = label;
        opt.textContent = label;
        timeSelect.appendChild(opt);
      }
    };

    /* Pre-populate next available slot so the form is 1-click ready.
       Audit 2026-04-21 §2: 98.8% of visitors drop before add-to-cart,
       partly because date/time are mandatory. Autofilling removes friction
       while still letting the user change either field. */
    (function autofillNextSlot() {
      var today = new Date();
      var londonNow = new Date(today.toLocaleString('en-GB', { timeZone: 'Europe/London' }));
      var candidate = new Date(londonNow);
      /* If today is already past cutoff (Fri close 17:30, other weekdays 17:30),
         or today is a weekend/holiday, roll forward until we land on a bookable day. */
      for (var i = 0; i < 10; i++) {
        var dow = candidate.getDay();
        var mo = candidate.getMonth() + 1;
        var dd = candidate.getDate();
        var candidateDateValue = formatDateValue(candidate);
        var isHoliday = (mo === 12 && dd >= 24) || (mo === 1 && dd <= 4);
        var isWeekend = dow === 0 || dow === 6;
        var isOneOffBlackout = !!getOneOffBlackoutMessage(candidateDateValue);
        if (!isHoliday && !isWeekend && !isOneOffBlackout) {
          var dayStartMin = (dow === 5) ? 600 : 570;
          var endMin = 1050;
          var sameDay = candidate.toDateString() === londonNow.toDateString();
          var cutoff = dayStartMin;
          if (sameDay) {
            var nowMin = londonNow.getHours() * 60 + londonNow.getMinutes();
            cutoff = Math.max(dayStartMin, Math.ceil(nowMin / 30) * 30 + 30);
          }
          if (cutoff < endMin) break;
        }
        candidate.setDate(candidate.getDate() + 1);
      }
      dateInput.value = formatDateValue(candidate);
      dateInput.dispatchEvent(new Event('change'));
      /* Pick first real time option (index 0 is the "Select a time" placeholder). */
      if (timeSelect.options.length > 1) {
        timeSelect.selectedIndex = 1;
      }
    })();
  }

  /* Turnaround cards: detected dynamically from the product page HTML.
     The product template renders .turn_arround_time-wrapper only if the
     turnaround metafield exists. We fetch the page, check for that marker,
     and parse the express price. Cached per handle. Zero maintenance. */
  var _expressCache = {};
  async function detectExpressFromPage(handle) {
    if (_expressCache[handle] !== undefined) return _expressCache[handle];
    try {
      var res = await fetch('/products/' + handle);
      if (!res.ok) { _expressCache[handle] = null; return null; }
      var html = await res.text();
      var marker = html.indexOf('turn_arround_time-wrapper');
      if (marker === -1) { _expressCache[handle] = null; return null; }
      var priceMatch = html.match(/id="one_day-btn"[^>]*data-price="([^"]+)"/);
      var price = priceMatch ? parseFloat(priceMatch[1]) : 0;
      var variantMatch = html.match(/id="one_day-btn"[^>]*value="(\d+)"/);
      var variantId = variantMatch ? parseInt(variantMatch[1], 10) : null;
      if (!price) {
        var fastSection = html.substring(marker, marker + 2000);
        var moneyMatch = fastSection.match(/\+[£](\d+(?:\.\d+)?)/);
        price = moneyMatch ? parseFloat(moneyMatch[1]) : 0;
      }
      if (!variantId) {
        var vidMatch = html.match(/name="turn_arround_time"[^>]*value="(\d+)"/);
        if (!vidMatch) vidMatch = html.match(/id="one_day-btn"[^>]*value="(\d+)"/);
        variantId = vidMatch ? parseInt(vidMatch[1], 10) : null;
      }
      var result = price ? { price: price, variantId: variantId } : null;
      _expressCache[handle] = result;
      return result;
    } catch(e) { _expressCache[handle] = null; return null; }
  }

  function buildTurnaroundCards(expressData) {
    if (!expressData || !expressData.price) return '';
    return '<div class="qw-opt-section">' +
      '<div class="qw-opt-label">Repair turnaround</div>' +
      '<div class="qw-opt-row">' +
        '<div class="qw-opt-card sel" data-opt="speed" data-add="0" data-vid="0" tabindex="0">' +
          '<div class="qw-opt-name">Standard</div>' +
          '<div class="qw-opt-meta">2-3 Working Days</div>' +
          '<div class="qw-opt-price free">Included</div>' +
        '</div>' +
        '<div class="qw-opt-card" data-opt="speed" data-add="' + expressData.price + '" data-vid="' + (expressData.variantId || 0) + '" tabindex="0">' +
          '<div class="qw-opt-name">Fast</div>' +
          '<div class="qw-opt-meta">1 Working Day</div>' +
          '<div class="qw-opt-price">+' + gbp.format(expressData.price) + '</div>' +
        '</div>' +
      '</div>' +
    '</div>';
  }

  /* =============================================
     NAVIGATION + BREADCRUMB + PROGRESS
     ============================================= */
  function go(n) {
    if (n < S.step) clearTrackedStepsAfter(n);
    S.step = n;
    _stepStartTime = Date.now();
    history.pushState({ step: n, device: S.device, model: S.model, fault: S.fault }, '');
    document.querySelectorAll('.qw-step').forEach(function(el) { el.classList.remove('on'); });
    var stepEl = document.getElementById('qw-s' + n);
    if (stepEl) stepEl.classList.add('on');
    updateProg(n);
    updateCrumb();
    if (!_suppressScroll) scrollToEl(document.querySelector('.qw-prog') || document.querySelector('.qw-wizard'), 100);
  }

  function updateProg(step) {
    document.querySelectorAll('.qw-prog-s').forEach(function(el) {
      var s = parseInt(el.dataset.s);
      el.classList.remove('on', 'done');
      if (s < step) el.classList.add('done');
      else if (s === step) el.classList.add('on');
    });
  }

  /* [4.3] Breadcrumb */
  function updateCrumb() {
    var el = document.getElementById('qw-crumb');
    if (!el) return;
    var parts = [];
    if (S.device) parts.push({ label: DN[S.device] || S.device, step: 1 });
    if (S.model) parts.push({ label: S.model, step: 2 });
    if (S.fault && S.step >= 4) parts.push({ label: S.fault, step: 3 });
    if (parts.length === 0) { el.innerHTML = ''; return; }
    el.innerHTML = parts.map(function(p, i) {
      var sep = i > 0 ? '<span class="qw-crumb-sep">&rsaquo;</span>' : '';
      return sep + '<button class="qw-crumb-btn" data-go="' + p.step + '">' + esc(p.label) + '</button>';
    }).join('');
    el.querySelectorAll('.qw-crumb-btn').forEach(function(btn) {
      btn.onclick = function() { var t = parseInt(btn.dataset.go); if (t < S.step) go(t); };
    });
  }

  /* [4.4] Clickable progress dots */
  function wireProgDots() {
    document.querySelectorAll('.qw-prog-s').forEach(function(el) {
      el.style.cursor = 'pointer';
      el.onclick = function() {
        var target = parseInt(el.dataset.s);
        if (target < S.step) go(target);
      };
    });
  }

