          '<div class="qw-opt-name">Fast</div>' +
          '<div class="qw-opt-meta">1 Working Day</div>' +
          '<div class="qw-opt-price">+' + gbp.format(expressData.price) + '</div>' +
        '</div>' +
      '</div>' +
    '</div>';
  }

  /* =============================================
     NAVIGATION + BREADCRUMB + PROGRESS
     ============================================= */
  function go(n) {
    S.step = n;
    _stepStartTime = Date.now();
    history.pushState({ step: n, device: S.device, model: S.model, fault: S.fault }, '');
    document.querySelectorAll('.qw-step').forEach(function(el) { el.classList.remove('on'); });
    var stepEl = document.getElementById('qw-s' + n);
    if (stepEl) stepEl.classList.add('on');
    updateProg(n);
    updateCrumb();
    if (!_suppressScroll) scrollToEl(document.querySelector('.qw-wizard'), 100);
  }

  function updateProg(step) {
    document.querySelectorAll('.qw-prog-s').forEach(function(el) {
      var s = parseInt(el.dataset.s);
      el.classList.remove('on', 'done');
      if (s < step) el.classList.add('done');
      else if (s === step) el.classList.add('on');
    });
  }

  /* [4.3] Breadcrumb */
  function updateCrumb() {
    var el = document.getElementById('qw-crumb');
    if (!el) return;
    var parts = [];
    if (S.device) parts.push({ label: DN[S.device] || S.device, step: 1 });
    if (S.model) parts.push({ label: S.model, step: 2 });
    if (S.fault && S.step >= 4) parts.push({ label: S.fault, step: 3 });
    if (parts.length === 0) { el.innerHTML = ''; return; }
    el.innerHTML = parts.map(function(p, i) {
      var sep = i > 0 ? '<span class="qw-crumb-sep">&rsaquo;</span>' : '';
      return sep + '<button class="qw-crumb-btn" data-go="' + p.step + '">' + esc(p.label) + '</button>';
    }).join('');
    el.querySelectorAll('.qw-crumb-btn').forEach(function(btn) {
      btn.onclick = function() { var t = parseInt(btn.dataset.go); if (t < S.step) go(t); };
    });
  }

  /* [4.4] Clickable progress dots */
  function wireProgDots() {
    document.querySelectorAll('.qw-prog-s').forEach(function(el) {
      el.style.cursor = 'pointer';
      el.onclick = function() {
        var target = parseInt(el.dataset.s);
        if (target < S.step) go(target);
      };
    });
  }

