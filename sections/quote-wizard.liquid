  function pickFault(v, el) {
    S.fault = v; S.issue = null; S.route = null; S.repairType = null;
    clearTrackedStepsAfter(3);
    document.querySelectorAll('#qw-s3 .qw-f-card').forEach(function(c) { c.classList.remove('sel'); });
    if (el) el.classList.add('sel');
    trackWizardStart({
      start_step: 'fault',
      step_name: 'fault',
      step_number: 3
    });
    trackWizardStepComplete('fault', 3, {
      selected_fault: v
    });
    trackWizardStep(4);

    /* "Other" skips issues and goes straight to contact */
    if (v === 'Other') {
      S.issue = 'Other';
      setTimeout(function() {
        var tC = document.getElementById('qw-tC'); if (tC) tC.innerHTML = '';
        var rP = document.getElementById('qw-rP'); if (rP) { rP.style.display = 'none'; rP.innerHTML = ''; }
        go(4);
        var titleEl = document.getElementById('qw-s4t'); if (titleEl) titleEl.textContent = 'Tell us what\'s going on';
        var subEl = document.getElementById('qw-s4s'); if (subEl) subEl.textContent = 'Describe the issue and we\'ll get back to you with the right repair option.';
        showResolution({ label: 'Other', route: 'contact', repairType: null, copy: 'Tell us what\'s happening with your ' + (DN[S.device] || 'device') + ' and we\'ll point you in the right direction.' });
      }, 150);
      return;
    }

    setTimeout(function() { renderIssues(S.device, v); go(4); }, 150);
  }

  /* =============================================
     STEP 4: ISSUES
     ============================================= */
  function renderIssues(dev, fault) {
    var c = document.getElementById('qw-tC');
    if (!c) return;
    c.innerHTML = '';
    var rP = document.getElementById('qw-rP');
    if (rP) { rP.style.display = 'none'; rP.innerHTML = ''; }
    destroyStickyCTA();

    var issues = getAvailableIssues(dev, fault, _repairsMap);
    var titleEl = document.getElementById('qw-s4t');
    if (titleEl) titleEl.textContent = fault;
    var subEl = document.getElementById('qw-s4s');
    if (subEl) subEl.textContent = 'Which best describes the problem?';

    var faultObj = (FAULTS[dev] || []).find(function(f) { return f.v === fault; });
    var fi = FAULT_ICONS[(faultObj && faultObj.icon) || 'other'] || FAULT_ICONS.other;

    if (issues.length === 0) {
      c.innerHTML = '<div class="qw-empty"><p>No specific issues found. Get in touch and we\'ll help.</p><a href="/pages/contact" class="qw-btn-book">Get in touch</a></div>';
      return;
    }
    issues.forEach(function(iss) {
      var card = document.createElement('div');
      card.className = 'qw-t-card';
      card.innerHTML = '<div class="qw-tw">' + fi + '</div><span class="qw-tt">' + esc(iss.label) + '</span>';
      wireA11y(card, iss.label);
      card.onclick = function() { pickIssue(iss, card); };
      c.appendChild(card);
    });
  }

  function pickIssue(iss, el) {
    S.issue = iss.label;
    S.route = iss.route || null;
    S.repairType = iss.repairType || null;
    delete _trackedSteps.resolution;
    document.querySelectorAll('#qw-s4 .qw-t-card').forEach(function(c) { c.classList.remove('sel'); });
    if (el) el.classList.add('sel');
    trackWizardStart({
      start_step: 'issue',
      step_name: 'issue',
      step_number: 4
    });
    trackWizardStepComplete('issue', 4, {
      selected_issue: iss.label,
      outcome_route: iss.route || null
    });
    trackWizardStep('resolution');

    /* Dustgate sub-question: if this issue has dustgateCheck and dustgate product exists */
    if (iss.dustgateCheck && _repairsMap['dustgate']) {
      showDustgateQuestion(iss);
    } else if (iss.flexgateCheck && _repairsMap['flexgate']) {
      showFlexgateQuestion(iss);
    } else {
      showResolution(iss);
    }
  }

