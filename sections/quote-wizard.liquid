              <span class="qw-hrs-d">Thu</span><span class="qw-hrs-t">{{ section.settings.hours_thu | default: '9am - 6pm' }}</span>
              <span class="qw-hrs-d">Fri</span><span class="qw-hrs-t">{{ section.settings.hours_fri | default: '10am - 6pm' }}</span>
