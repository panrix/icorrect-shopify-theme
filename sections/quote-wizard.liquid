        document.getElementById('qwq-phone-err'),
        submitBtn
      );
    }

    nameIn.addEventListener('input', validate);
    emailIn.addEventListener('input', validate);
    phoneIn.addEventListener('input', validate);

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      if (!validate()) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      var payload = {
        source: 'quote-wizard-question',
        device: S.device || '',
        model: S.model || '',
        fault: S.fault || '',
        issue: S.issue || '',
        route: 'question',
        name: nameIn.value.trim(),
        email: emailIn.value.trim(),
        phone: phoneIn.value.trim(),
        message: (document.getElementById('qwq-message').value || '').trim(),
        url: window.location.href,
        timestamp: new Date().toISOString()
      };

      fetch('https://icorrect.app.n8n.cloud/workflow/tNQphRiUo0L8SdBn', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
      .then(function(res) {
        if (res.ok) {
          form.innerHTML = '<div class="qw-success"><p>Thanks! We\'ll be in touch shortly.</p></div>';
          if (window.posthog) {
            posthog.capture('wizard_conversion', {
              action: 'question_submit', device: S.device, model: S.model, fault: S.fault, issue: S.issue
            });
          }
        } else {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send';
          var errDiv = form.querySelector('.qw-form-error') || document.createElement('div');
          errDiv.className = 'qw-form-error';
          errDiv.textContent = 'Something went wrong. Please try again.';
          if (!form.querySelector('.qw-form-error')) form.appendChild(errDiv);
        }
      })
      .catch(function() {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send';
        var errDiv = form.querySelector('.qw-form-error') || document.createElement('div');
        errDiv.className = 'qw-form-error';
        errDiv.textContent = 'Something went wrong. Please try again.';
        if (!form.querySelector('.qw-form-error')) form.appendChild(errDiv);
      });
    });
  }

  // === PRE-FILL SYSTEM ===
  function findModelByCollection(handle) {
    var devices = ['macbook', 'iphone', 'ipad', 'watch'];
    for (var d = 0; d < devices.length; d++) {
      var groups = MODELS[devices[d]];
      if (!groups) continue;
      for (var g = 0; g < groups.length; g++) {
        for (var m = 0; m < groups[g].models.length; m++) {
          if (groups[g].models[m].collectionHandle === handle) {
            return { device: devices[d], model: groups[g].models[m] };
          }
        }
      }
    }
    return null;
  }

  function initPrefill() {
    var ctx = CONTEXT;
    if (!ctx) { go(1); return; }

    // Priority 1: Collection handle matches a model
    if (ctx.collectionHandle) {
      var modelMatch = findModelByCollection(ctx.collectionHandle);
      if (modelMatch) {
        S.device = modelMatch.device;
        S.model = modelMatch.model.name;
        S.collectionHandle = modelMatch.model.collectionHandle;
        pickModel(modelMatch.model.name, modelMatch.model.collectionHandle);
        return;
      }
    }

    // Priority 2: Device metafield
    if (ctx.device) {
      S.device = ctx.device;
      if (ctx.fault) S.preFault = ctx.fault;
      go(2);
      return;
    }

    // No context — start fresh
    go(1);
  }

  // === BROWSER BACK BUTTON ===
  window.addEventListener('popstate', function(e) {
    if (e.state && typeof e.state.step === 'number') {
      S.device = e.state.device || null;
      S.model = e.state.model || null;
      S.fault = e.state.fault || null;
      S.issue = null;
      renderStep(e.state.step);
      updateProgress(e.state.step);
    }
  });

  // === INIT ===
  initPrefill();

})();
</script>

