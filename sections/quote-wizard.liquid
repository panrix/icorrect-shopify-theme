  /* =============================================
     STEP 2: MODELS (accordion + auto-expand)
     ============================================= */
  /* Sort models: newest year first, then highest M-chip first within same year */
  function sortModels(models) {
    return models.slice().sort(function(a, b) {
      var ya = parseInt((a.name.match(/\((\d{4})\)/) || [])[1]) || 0;
      var yb = parseInt((b.name.match(/\((\d{4})\)/) || [])[1]) || 0;
      if (yb !== ya) return yb - ya;
      /* Extract M-chip number: M4=4, M3=3, M2=2, M1=1, none=0 */
      var ma = parseInt((a.name.match(/M(\d)/i) || [])[1]) || 0;
      var mb = parseInt((b.name.match(/M(\d)/i) || [])[1]) || 0;
      if (mb !== ma) return mb - ma;
      /* Within same chip, Max > Pro > base */
      var ra = a.name.indexOf('Max') !== -1 ? 3 : a.name.indexOf('Pro') !== -1 ? 2 : 1;
      var rb = b.name.indexOf('Max') !== -1 ? 3 : b.name.indexOf('Pro') !== -1 ? 2 : 1;
      return rb - ra;
    });
  }

  function renderModels(dev) {
    var c = document.getElementById('qw-mC');
    if (!c) return;
    c.innerHTML = '';
    var titleEl = document.getElementById('qw-s2t');
    if (titleEl) titleEl.textContent = 'Pick your ' + DN[dev] + ' model';
    var hP = document.getElementById('qw-hP');
    if (hP) { hP.classList.remove('open'); hP.innerHTML = ''; }

    var groups = MODELS[dev];
    if (!groups || groups.length === 0) {
      c.innerHTML = '<div class="qw-empty"><p>We don\'t have pricing for this model yet. Get in touch for a quote.</p><a href="/pages/contact" class="qw-btn-book">Get in touch</a></div>';
      return;
    }

    var w = document.createElement('div'); w.className = 'qw-m-groups';
    groups.forEach(function(g, gi) {
      var ge = document.createElement('div'); ge.className = 'qw-m-group';
      var h = document.createElement('div'); h.className = 'qw-m-head';
      h.innerHTML = '<div><span class="qw-m-name">' + esc(g.group) + '</span><span class="qw-m-count">' + g.models.length + ' models</span></div><svg class="qw-m-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>';
      h.onclick = function() {
        var wasOpen = ge.classList.contains('open');
        w.querySelectorAll('.qw-m-group.open').forEach(function(g) { g.classList.remove('open'); });
        if (!wasOpen) ge.classList.add('open');
      };
      ge.appendChild(h);

      var b = document.createElement('div'); b.className = 'qw-m-body';
      var l = document.createElement('div'); l.className = 'qw-m-list';
      var sorted = sortModels(g.models);
      sorted.forEach(function(m) {
        var it = document.createElement('div'); it.className = 'qw-m-item';
        it.innerHTML = '<span class="qw-mn">' + esc(m.name) + '</span>';
        wireA11y(it, 'Select ' + m.name);
        it.onclick = function() { pickModel(m.name, m.collectionHandle, it); };
        l.appendChild(it);
      });
      b.appendChild(l); ge.appendChild(b); w.appendChild(ge);
    });
    c.appendChild(w);
    renderHelper(dev);
  }

  async function pickModel(name, handle, el) {
    S.model = name; S.collectionHandle = handle; S.fault = null; S.issue = null; S.route = null; S.repairType = null;
    clearTrackedStepsAfter(2);
    /* [3.6] Auto-close helper */
    var hP = document.getElementById('qw-hP');
    if (hP) hP.classList.remove('open');
    document.querySelectorAll('.qw-m-item').forEach(function(c) { c.classList.remove('sel'); });
    if (el) el.classList.add('sel');

    var fGrid = document.querySelector('#qw-s3 .qw-f-grid');
    if (fGrid) fGrid.innerHTML = '<div class="qw-loading"><div class="qw-spinner"></div><p>Loading repairs for ' + esc(name) + '...</p></div>';

    var products = await fetchCollection(handle);
    _collectionProducts = products;
    _repairsMap = buildRepairsMap(products);
    trackWizardStart({
      start_step: 'model',
      step_name: 'model',
      step_number: 2
    });
    trackWizardStepComplete('model', 2, {
      collection_handle: handle
    });

    trackWizardStep(3);

    if (S.preFault) {
      var pf = S.preFault; S.preFault = null; S.fault = pf;
      renderFaults(S.device);
      renderIssues(S.device, pf);
      trackWizardStep(4);
      go(4);
      return;
    }
    renderFaults(S.device);
    go(3);
  }

