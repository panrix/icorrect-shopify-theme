          }
          /* Fallback */
          S.model = n.m;
          panel.classList.remove('open');
          renderFaults(S.device);
          go(3);
        };
        r.appendChild(d);
      });
    }

    document.getElementById('qwMbSearch').oninput = mbFilter;
    mbFilter();
