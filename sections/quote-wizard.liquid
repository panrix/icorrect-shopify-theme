              <span class="qw-hrs-d">Sun</span><span class="qw-hrs-t qw-hrs-c">Closed</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    {%- endif -%}

    <!-- RIGHT: WIZARD -->
    <div class="qw-wizard" aria-label="Repair quote wizard">
      <div class="qw-head">
        <h2 class="qw-title">{{ section.settings.heading }}</h2>
        <p class="qw-sub">{{ section.settings.subheading }}</p>
      </div>

      <!-- Step indicator: numbered circles -->
      <div class="qw-prog" role="navigation" aria-label="Progress">
        <div class="qw-prog-s on" data-s="1"><div class="qw-prog-dot">1</div><span class="qw-prog-lbl">Device</span><div class="qw-prog-line"></div></div>
        <div class="qw-prog-s" data-s="2"><div class="qw-prog-dot">2</div><span class="qw-prog-lbl">Model</span><div class="qw-prog-line"></div></div>
        <div class="qw-prog-s" data-s="3"><div class="qw-prog-dot">3</div><span class="qw-prog-lbl">Fault</span><div class="qw-prog-line"></div></div>
        <div class="qw-prog-s" data-s="4"><div class="qw-prog-dot">4</div><span class="qw-prog-lbl">Result</span></div>
      </div>

      <!-- Step 1: Devices -->
      <div class="qw-step on" id="qw-s1">
        <h3 class="qw-s-title">What needs fixing?</h3>
        <p class="qw-s-sub">Pick your device to get started.</p>
        <div class="qw-dev-grid" id="qw-devGrid"></div>
      </div>

      <!-- Step 2: Models -->
      <div class="qw-step" id="qw-s2">
        <button class="qw-back" id="qw-back2"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>Back</button>
        <h3 class="qw-s-title" id="qw-s2t"></h3>
        <p class="qw-s-sub">Pick your exact model for accurate pricing.</p>
        <div id="qw-mC"></div>
        <button class="qw-help-trig" id="qw-hT">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          Not sure which model? We'll help you find it.
        </button>
        <div class="qw-help-panel" id="qw-hP"></div>
      </div>

      <!-- Step 3: Faults -->
      <div class="qw-step" id="qw-s3">
        <button class="qw-back" id="qw-back3"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>Back</button>
        <h3 class="qw-s-title" id="qw-s3t"></h3>
        <p class="qw-s-sub">Pick the category that fits best.</p>
        <div class="qw-f-grid" id="qw-fC"></div>
      </div>

      <!-- Step 4: Issues + Result -->
      <div class="qw-step" id="qw-s4">
        <button class="qw-back" id="qw-back4"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>Back</button>
        <h3 class="qw-s-title" id="qw-s4t"></h3>
        <p class="qw-s-sub" id="qw-s4s"></p>
        <div class="qw-t-grid" id="qw-tC"></div>
        <div id="qw-rP" style="display:none;margin-top:20px;"></div>
      </div>
    </div>

  </div>
</div>

