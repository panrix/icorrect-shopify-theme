  /* Centralized scroll: precise, firm, no clunkiness.
     Scrolls so the target element sits 20px below the viewport top.
     Uses requestAnimationFrame to ensure DOM has settled. */
  var _scrollLock = false;
  function scrollToEl(el, delay) {
    if (!el || _scrollLock) return;
    _scrollLock = true;
    setTimeout(function() {
      requestAnimationFrame(function() {
        var rect = el.getBoundingClientRect();
        var targetY = rect.top + window.pageYOffset - 20;
        window.scrollTo({ top: Math.max(0, targetY), behavior: 'smooth' });
        _scrollLock = false;
      });
    }, delay || 80);
  }

  /* [4.7] Shared a11y helper */
  function wireA11y(el, label) {
    if (label) el.setAttribute('aria-label', label);
    el.setAttribute('role', 'button');
