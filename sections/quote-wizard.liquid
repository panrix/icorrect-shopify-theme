  function deriveRepairTypeFromHandle(handle) {
    var keys = Object.keys(HANDLE_SUFFIX_MAP);
    keys.sort(function(a, b) { return b.length - a.length; });
    for (var i = 0; i < keys.length; i++) { if (handle.endsWith(keys[i])) return HANDLE_SUFFIX_MAP[keys[i]]; }
    return null;
  }

  async function fetchCollection(handle) {
    if (_collectionCache[handle]) return _collectionCache[handle];
    try {
      var res = await fetch('/collections/' + handle + '/products.json?limit=250');
      if (!res.ok) {
        trackWizardEventOnce('collection-fetch:' + handle + ':' + res.status, 'wizard_collection_fetch_failed', {
          collectionHandle: handle,
          status: res.status,
          failureType: 'http'
        });
        return [];
      }
      var data = await res.json();
      _collectionCache[handle] = data.products;
      return data.products;
    } catch(e) {
      trackWizardEventOnce('collection-fetch:' + handle + ':network', 'wizard_collection_fetch_failed', {
        collectionHandle: handle,
        failureType: 'network',
        errorMessage: e && e.message ? e.message : null
      });
      return [];
    }
  }

  function buildRepairsMap(products) {
    var map = {};
    for (var i = 0; i < products.length; i++) {
      var rt = deriveRepairTypeFromHandle(products[i].handle);
      if (rt) map[rt] = products[i];
    }
    return map;
  }

  function getProductsForRepairType(repairType) {
    return (_collectionProducts || []).filter(function(product) {
      return deriveRepairTypeFromHandle(product.handle) === repairType;
    });
  }

  function pickProductByHandlePreference(products, patterns) {
    for (var i = 0; i < patterns.length; i++) {
      for (var j = 0; j < products.length; j++) {
        if (products[j].handle.indexOf(patterns[i]) !== -1) return products[j];
      }
    }
    return products[0] || null;
  }

  function resolveRepairProduct(repairType, issueLabel) {
    var products = getProductsForRepairType(repairType);
    if (!products.length) return null;
    if (products.length === 1) return products[0];

    var issue = (issueLabel || '').toLowerCase();

    if (repairType === 'rear-glass') {
      return pickProductByHandlePreference(products, [
        'rear-glass-repair',
        'housing-rear-glass-repair',
        'housing-repair'
      ]);
    }

    if (repairType === 'screen') {
      if (issue.indexOf('black screen') !== -1 || issue.indexOf('no display') !== -1 || issue.indexOf('no screen') !== -1) {
        return pickProductByHandlePreference(products, [
          'original-lcd-screen-no-screen-message-repair',
          'display-screen-repair',
          'screen-repair',
          'original-screen-repair'
        ]);
      }
      return pickProductByHandlePreference(products, [
        'original-screen-repair',
        'display-screen-repair',
        'screen-repair',
        'original-lcd-screen-no-screen-message-repair'
      ]);
    }

    return products[0];
  }

