{{ 'icorrect-redesign-tokens.css' | asset_url | stylesheet_tag }}
{{ 'icorrect-collection-redesign.css' | asset_url | stylesheet_tag }}

{%- assign repair_collection = collections[section.settings.collection] | default: collection -%}

<section class="icr-design product-grid">
  <div class="container">
    <div class="pg-head">
      <div>
        <div class="mono-label">{{ section.settings.eyebrow }}</div>
        <h2>{{ section.settings.heading }}</h2>
      </div>
      <div class="pg-foot-note">{{ repair_collection.products_count }} services · Genuine Apple parts · 2-year warranty</div>
    </div>

    <div class="pg">
      {%- for product in repair_collection.products -%}
        {%- capture search_text -%}{{ product.title }} {{ product.handle }} {{ product.tags | join: ' ' }}{%- endcapture -%}
        <a class="pg-item" href="{{ product.url }}" data-icr-product-card data-search="{{ search_text | escape }}">
          <span class="pg-thumb">
            {%- if product.featured_image -%}
              {{ product.featured_image | image_url: width: 520 | image_tag: loading: 'lazy', widths: '260, 390, 520', alt: product.title }}
            {%- else -%}
              <svg width="64" height="44" viewBox="0 0 64 44" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><rect x="8" y="4" width="48" height="30" rx="2"/><rect x="2" y="34" width="60" height="4" rx="1"/><line x1="28" y1="38" x2="36" y2="38"/></svg>
            {%- endif -%}
          </span>
          <span class="pg-name">{{ product.title }}</span>
          <span class="pg-price"><span>{{ product.price | money_without_trailing_zeros }}</span> · {{ product.available | default: false | replace: 'true', 'Available' | replace: 'false', 'Check stock' }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "iCorrect repair grid",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Repair collection" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "All repairs" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Browse every MacBook screen repair we offer." },
    { "type": "textarea", "id": "lede", "label": "Lede", "default": "The wizard is the fastest route, but every product remains browsable with its live Shopify price and URL." }
  ],
  "presets": [
    { "name": "iCorrect repair grid" }
  ]
}
{% endschema %}
