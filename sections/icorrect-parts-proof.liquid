{{ 'icorrect-redesign-tokens.css' | asset_url | stylesheet_tag }}
{{ 'icorrect-collection-redesign.css' | asset_url | stylesheet_tag }}

<section class="icr-design info info-parts">
  <div class="container info-parts-grid">
    <div class="info-parts-text">
      <div class="mono-label">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.lede }}</p>
      <dl class="info-parts-dl">
        {%- for block in section.blocks -%}
          <dt {{ block.shopify_attributes }}>{{ block.settings.key }}</dt>
          <dd>{{ block.settings.value }}</dd>
        {%- endfor -%}
      </dl>
    </div>

    <aside class="info-parts-card" aria-label="Parts workflow">
      <div class="info-parts-card-top">
        <div class="mono-label">{{ section.settings.panel_eyebrow }}</div>
        <div class="info-badge">Verified</div>
      </div>
      <div class="info-parts-chain">
        <div class="info-parts-node"><div class="info-parts-node-title">{{ section.settings.node_1_title }}</div><div class="info-parts-node-body">{{ section.settings.node_1_copy }}</div></div>
        <div class="info-parts-arrow">↓</div>
        <div class="info-parts-node"><div class="info-parts-node-title">{{ section.settings.node_2_title }}</div><div class="info-parts-node-body">{{ section.settings.node_2_copy }}</div></div>
        <div class="info-parts-arrow">↓</div>
        <div class="info-parts-node"><div class="info-parts-node-title">{{ section.settings.node_3_title }}</div><div class="info-parts-node-body">{{ section.settings.node_3_copy }}</div></div>
      </div>
    </aside>
  </div>
</section>

{% schema %}
{
  "name": "iCorrect parts proof",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Parts and materials" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Apple OEM displays, recalibrated in-house." },
    { "type": "textarea", "id": "lede", "label": "Lede", "default": "The first build preserves the design direction while keeping detailed claims editable for the content review." },
    { "type": "text", "id": "panel_eyebrow", "label": "Panel eyebrow", "default": "Supply chain" },
    { "type": "text", "id": "node_1_title", "label": "Node 1 title", "default": "Genuine Apple assemblies" },
    { "type": "textarea", "id": "node_1_copy", "label": "Node 1 copy", "default": "Original displays selected for condition and compatibility." },
    { "type": "text", "id": "node_2_title", "label": "Node 2 title", "default": "Workshop calibration" },
    { "type": "textarea", "id": "node_2_copy", "label": "Node 2 copy", "default": "Brightness, colour, camera, and True Tone checks before return." },
    { "type": "text", "id": "node_3_title", "label": "Node 3 title", "default": "Two-year warranty" },
    { "type": "textarea", "id": "node_3_copy", "label": "Node 3 copy", "default": "Parts and labour cover for the display assembly we fit." }
  ],
  "blocks": [
    {
      "type": "fact",
      "name": "Fact",
      "settings": [
        { "type": "text", "id": "key", "label": "Key", "default": "Source" },
        { "type": "textarea", "id": "value", "label": "Value", "default": "Genuine Apple display assemblies, tested before fitting." }
      ]
    }
  ],
  "presets": [
    {
      "name": "iCorrect parts proof",
      "blocks": [
        { "type": "fact", "settings": { "key": "Source", "value": "Genuine Apple display assemblies, tested before fitting." } },
        { "type": "fact", "settings": { "key": "Calibration", "value": "Brightness, colour, camera, and sensor checks before collection." } },
        { "type": "fact", "settings": { "key": "Sustainability", "value": "Where possible we preserve working housings, hinges, antennas, and cameras." } }
      ]
    }
  ]
}
{% endschema %}
