<section class="video-reviews-{{ section.id }}" data-video-reviews-section>
  <div class="video-reviews-wrapper page-width">
    <div class="video-reviews-top-info">
      <div class="reviews-heading">
        <h2>{{ section.settings.heading }}</h2>
      </div>
      <div class="reviews-social-icons">
        <div class="social-icons-row">
          {% if section.settings.facebook != blank and section.settings.facebook-icon != blank %}
            <a href="{{ section.settings.facebook }}" aria-label="Visit iCorrect on Facebook">
              <img src="{{ section.settings.facebook-icon | image_url }}" alt="" loading="lazy">
            </a>
          {% endif %}
          {% if section.settings.insta != blank and section.settings.insta-icon != blank %}
            <a href="{{ section.settings.insta }}" aria-label="Visit iCorrect on Instagram">
              <img src="{{ section.settings.insta-icon | image_url }}" alt="" loading="lazy">
            </a>
          {% endif %}
          {% if section.settings.tiktok != blank and section.settings.tiktok-icon != blank %}
            <a href="{{ section.settings.tiktok }}" aria-label="Visit iCorrect on TikTok">
              <img src="{{ section.settings.tiktok-icon | image_url }}" alt="" loading="lazy">
            </a>
          {% endif %}
          {% if section.settings.youtube != blank and section.settings.youtube-icon != blank %}
            <a href="{{ section.settings.youtube }}" aria-label="Visit iCorrect on YouTube">
              <img src="{{ section.settings.youtube-icon | image_url }}" alt="" loading="lazy">
            </a>
          {% endif %}
        </div>
      </div>
    </div>
    <div
      class="video-reviews-row"
      data-video-reviews-track
      {% if section.blocks.size > 1 %}
        aria-label="{{ section.settings.heading | escape }}"
      {% endif %}
    >
      {% for block in section.blocks %}
        <div class="video-review-col" {{ block.shopify_attributes }}>
          {% if block.settings.video != blank %}
            <video
              class="cust_video cust_video_auto"
              width="100%"
              height="auto"
              controls
              playsinline
              preload="metadata"
              src="{{ block.settings.video }}"
            ></video>
          {% else %}
            <img
              src="{{ block.settings.img | image_url }}"
              alt="{{ block.settings.img.alt | default: 'Customer review preview' | escape }}"
              loading="lazy"
            >
          {% endif %}
        </div>
      {% endfor %}
    </div>
    {% if section.blocks.size > 1 %}
      <div class="video-reviews-controls" aria-label="Video review navigation">
        <button type="button" class="video-reviews-control" data-video-reviews-prev aria-label="Show previous review">
          Prev
        </button>
        <button type="button" class="video-reviews-control" data-video-reviews-next aria-label="Show next review">
          Next
        </button>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .video-reviews-{{ section.id }}{
    padding-top: {{ section.settings.padding-top }}px;
    padding-bottom: {{ section.settings.padding-bottom }}px;
    width: 100%;
    background-color: {{ section.settings.bg }};
  }

  .video-reviews-top-info{
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: space-between;
    padding-bottom: 40px;
  }
  .reviews-heading{
    flex: 50%;
    max-width: 50%;
    text-align: left;
  }
  .reviews-heading h2{
   color: #fff;
font-size: 28px;
font-weight: 600;
line-height: 45.67px;
text-align: left;
margin: 0;
    padding: 0;
  }
  .reviews-social-icons{
    flex: 50%;
    max-width: 50%;
    align-self: flex-end;
    text-align: right;
  }
  .social-icons-row{
    display: flex;
    align-items: center;
    column-gap: 15px;
    justify-content: flex-end;
  }
  .social-icons-row a{
    max-width: 32px;
  }
  .social-icons-row a img{
    width: 100%;
    height: auto;
    display: block;
  }
  .video-reviews-row{
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 3.3545%;
  }
  .video-reviews-row .video-review-col{
    flex: 31.097%;
    max-width: 31.097%;
  }
  .video-review-col img, .video-review-col video{
    width: 100%;
    height: auto;
    display: block;
    border-radius: 16px;
  }
  .video-reviews-controls{
    display: none;
  }
  @media(max-width: 767px){
    .video-reviews-{{ section.id }}{
      padding-top: {{ section.settings.mob-padding-top }}px;
      padding-bottom: {{ section.settings.mob-padding-bottom }}px;
    }
    .video-reviews-top-info{
      padding-bottom: 20px;
    }
    .reviews-heading{
    flex: 100%;
    max-width: 100%;
    text-align: left;
      padding-bottom: 15px;
  }
   .reviews-heading h2{
font-size: 24px;
font-weight: 600;
line-height: 36px;
text-align: left;

    }
    .reviews-social-icons{
      flex: 100%;
    max-width: 100%;
    text-align: left;
      align-self: flex-start;
    }
    .social-icons-row{
      justify-content: flex-start;
    }
    .social-icons-row a{
      max-width: 26px;
    }
    .video-reviews-row{
      justify-content: flex-start;
      gap: 20px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 8px;
    }
    .video-reviews-row::-webkit-scrollbar{
      display: none;
    }
    .video-reviews-row .video-review-col{
      flex: 0 0 calc(100% - 56px);
      max-width: calc(100% - 56px);
      scroll-snap-align: start;
    }
    .video-reviews-controls{
      display: flex;
      justify-content: flex-end;
      gap: 12px;
      margin-top: 20px;
    }
    .video-reviews-control{
      min-width: 68px;
      border: 1px solid rgba(255, 255, 255, 0.24);
      border-radius: 999px;
      background: transparent;
      color: #ffffff;
      font-size: 1.3rem;
      font-weight: 600;
      line-height: 1;
      padding: 10px 16px;
      cursor: pointer;
    }
    .video-reviews-control[disabled]{
      opacity: 0.35;
      cursor: default;
    }
  }
</style>

<script>
  (function() {
    const section = document.querySelector('.video-reviews-{{ section.id }}');
    if (!section) return;

    const track = section.querySelector('[data-video-reviews-track]');
    const cards = Array.from(section.querySelectorAll('.video-review-col'));
    const prevButton = section.querySelector('[data-video-reviews-prev]');
    const nextButton = section.querySelector('[data-video-reviews-next]');

    if (!track || cards.length < 2 || !prevButton || !nextButton) return;

    const mobileQuery = window.matchMedia('(max-width: 767px)');
    let activeIndex = 0;

    const getClosestIndex = () => {
      let closestIndex = 0;
      let closestOffset = Number.POSITIVE_INFINITY;

      cards.forEach((card, index) => {
        const offset = Math.abs(card.offsetLeft - track.scrollLeft);
        if (offset < closestOffset) {
          closestOffset = offset;
          closestIndex = index;
        }
      });

      return closestIndex;
    };

    const updateControls = () => {
      if (!mobileQuery.matches) {
        prevButton.disabled = true;
        nextButton.disabled = true;
        return;
      }

      activeIndex = getClosestIndex();
      prevButton.disabled = activeIndex <= 0;
      nextButton.disabled = activeIndex >= cards.length - 1;
    };

    const scrollToIndex = (index) => {
      const boundedIndex = Math.max(0, Math.min(cards.length - 1, index));
      track.scrollTo({
        left: cards[boundedIndex].offsetLeft,
        behavior: 'smooth'
      });
    };

    prevButton.addEventListener('click', () => {
      scrollToIndex(activeIndex - 1);
    });

    nextButton.addEventListener('click', () => {
      scrollToIndex(activeIndex + 1);
    });

    track.addEventListener('scroll', () => {
      window.requestAnimationFrame(updateControls);
    }, { passive: true });

    if (typeof mobileQuery.addEventListener === 'function') {
      mobileQuery.addEventListener('change', updateControls);
    } else if (typeof mobileQuery.addListener === 'function') {
      mobileQuery.addListener(updateControls);
    }

    window.addEventListener('resize', updateControls, { passive: true });
    updateControls();
  })();
</script>


