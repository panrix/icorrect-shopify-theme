{{ 'icorrect-redesign-tokens.css' | asset_url | stylesheet_tag }}
{{ 'icorrect-collection-redesign.css' | asset_url | stylesheet_tag }}

<section class="icr-design faq">
  <div class="container faq-grid">
    <div class="faq-left">
      <div class="mono-label">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.lede }}</p>
    </div>
    <div class="faq-right">
      {%- for block in section.blocks -%}
        <details class="faq-item{% if forloop.first %} open{% endif %}" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
          <summary class="faq-q">{{ block.settings.question }} <span class="icon">+</span></summary>
          <div class="faq-a">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "iCorrect redesign FAQ",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Frequently asked" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Questions, answered honestly." },
    { "type": "textarea", "id": "lede", "label": "Lede", "default": "Native details elements avoid the previous dead-click-prone accordion pattern and work cleanly on mobile." }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long does a MacBook screen repair take?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Most repairs are completed in 1-2 working days once the part and fault are confirmed.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "iCorrect redesign FAQ",
      "blocks": [
        { "type": "faq", "settings": { "question": "How long does a MacBook screen repair take?", "answer": "<p>Most repairs are completed in 1-2 working days once the part and fault are confirmed.</p>" } },
        { "type": "faq", "settings": { "question": "Are the replacement screens genuine Apple parts?", "answer": "<p>We use genuine Apple display assemblies and test them before fitting.</p>" } },
        { "type": "faq", "settings": { "question": "Is my data safe during repair?", "answer": "<p>Screen repairs do not require access to your files. We only request access if post-repair testing genuinely needs it.</p>" } }
      ]
    }
  ]
}
{% endschema %}
