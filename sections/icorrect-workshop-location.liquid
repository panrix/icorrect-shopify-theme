{{ 'icorrect-redesign-tokens.css' | asset_url | stylesheet_tag }}
{{ 'icorrect-collection-redesign.css' | asset_url | stylesheet_tag }}

<section class="icr-design location">
  <div class="container location-grid">
    <div>
      <div class="mono-label">{{ section.settings.eyebrow }}</div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.lede }}</p>
      <dl class="location-dl">
        <dt>Address</dt>
        <dd>{{ section.settings.address }}</dd>
        <dt>Phone</dt>
        <dd><a href="tel:{{ section.settings.phone | remove: ' ' | remove: '(' | remove: ')' }}">{{ section.settings.phone }}</a></dd>
        <dt>Email</dt>
        <dd><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></dd>
        <dt>Hours</dt>
        <dd>{{ section.settings.hours }}</dd>
      </dl>
    </div>
    <div class="location-map" aria-label="Map illustration for iCorrect Fitzrovia workshop">
      <div class="location-map-bg">
        {%- for i in (1..20) -%}
          <div class="map-street" style="top: {{ i | times: 11 | modulo: 100 }}%; left: {{ i | times: 17 | modulo: 100 }}%; width: {{ 40 | plus: i | times: 13 | modulo: 60 }}%; transform: rotate({{ i | times: 31 | modulo: 180 }}deg);"></div>
        {%- endfor -%}
      </div>
      <div class="location-map-pin">
        <div class="location-map-pin-card">
          <strong>iCorrect</strong>
          <span>{{ section.settings.pin_copy }}</span>
          <div class="location-map-pin-rating">★ 4.8 · 719 reviews</div>
        </div>
        <div class="location-map-marker">📍</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "iCorrect location",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Visit the workshop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Fitzrovia, London." },
    { "type": "textarea", "id": "lede", "label": "Lede", "default": "Opposite The London Palladium. Drop-in diagnosis, no appointment needed." },
    { "type": "richtext", "id": "address", "label": "Address", "default": "<p>12 Margaret Street<br>Audley House<br>London W1W 8JQ</p>" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "+44 (0)207 099 8517" },
    { "type": "text", "id": "email", "label": "Email", "default": "support@icorrect.co.uk" },
    { "type": "richtext", "id": "hours", "label": "Hours", "default": "<p>Mon-Thu 9am-6pm<br>Fri 10am-6pm<br>Sat/Sun closed</p>" },
    { "type": "text", "id": "pin_copy", "label": "Pin copy", "default": "12 Margaret St, London W1W 8JQ - 4.8 from 719 reviews" }
  ],
  "presets": [
    { "name": "iCorrect location" }
  ]
}
{% endschema %}
